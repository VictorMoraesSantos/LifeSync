<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             x:Class="LifeSyncApp.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource FinBackground}">

    <Grid>
        <!-- Content Area fills entire page -->
        <ContentView x:Name="ContentArea"/>

        <!-- Custom Tab Bar floats at the bottom with transparent background -->
        <controls:CustomTabBar x:Name="TabBar"
                              VerticalOptions="End"
                              TabSelected="OnTabSelected"/>
    </Grid>

</ContentPage>
