<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeSyncApp.Controls.SectionCard">

    <Border x:Name="CardBorder"
            BackgroundColor="{StaticResource FinCardBg}"
            StrokeThickness="1"
            Stroke="{StaticResource FinBorder}"
            StrokeShape="RoundRectangle 16">
        <Border.Shadow>
            <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
        </Border.Shadow>
    </Border>

</ContentView>
