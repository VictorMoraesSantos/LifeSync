<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeSyncApp.Controls.CustomTabBar"
             BackgroundColor="Transparent">

    <Border StrokeThickness="1"
            Stroke="{StaticResource FinBorder}"
            BackgroundColor="{StaticResource FinCardBg}"
            Padding="4"
            Margin="21,12,21,21"
            StrokeShape="RoundRectangle 36">
        <Border.Shadow>
            <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
        </Border.Shadow>

        <FlexLayout JustifyContent="SpaceAround"
                    AlignItems="Center"
                    BackgroundColor="Transparent"
                    HeightRequest="54">

            <!-- Financeiro Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=0}"
                    StrokeThickness="0"
                    WidthRequest="46" HeightRequest="46"
                    StrokeShape="RoundRectangle 100">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="0"/>
                </Border.GestureRecognizers>
                <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=financeiro}"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Acadêmico Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=1}"
                    StrokeThickness="0"
                    WidthRequest="46" HeightRequest="46"
                    StrokeShape="RoundRectangle 100">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="1"/>
                </Border.GestureRecognizers>
                <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=academico}"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Tarefas Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=2}"
                    StrokeThickness="0"
                    WidthRequest="46" HeightRequest="46"
                    StrokeShape="RoundRectangle 100">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="2"/>
                </Border.GestureRecognizers>
                <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=tarefas}"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Nutrição Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=3}"
                    StrokeThickness="0"
                    WidthRequest="46" HeightRequest="46"
                    StrokeShape="RoundRectangle 100">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="3"/>
                </Border.GestureRecognizers>
                <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=nutricao}"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

            <!-- Perfil Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=4}"
                    StrokeThickness="0"
                    WidthRequest="46" HeightRequest="46"
                    StrokeShape="RoundRectangle 100">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="4"/>
                </Border.GestureRecognizers>
                <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=perfil}"
                       WidthRequest="22" HeightRequest="22"
                       HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>

        </FlexLayout>
    </Border>
</ContentView>
