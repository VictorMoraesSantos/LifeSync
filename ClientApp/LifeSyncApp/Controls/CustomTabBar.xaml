<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeSyncApp.Controls.CustomTabBar"
             BackgroundColor="{StaticResource FinBackground}">

    <Border StrokeThickness="1"
            Stroke="{StaticResource FinBorder}"
            BackgroundColor="{StaticResource FinCardBg}"
            Padding="4"
            Margin="21,12,21,21"
            StrokeShape="RoundRectangle 36">
        <Border.Shadow>
            <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
        </Border.Shadow>

        <FlexLayout JustifyContent="SpaceAround"
                    AlignItems="Center"
                    BackgroundColor="Transparent"
                    HeightRequest="54">

            <!-- Financeiro Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=0}"
                    StrokeThickness="0"
                    Padding="8,16"
                    MinimumHeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="100"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="0"/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=financeiro}"
                           WidthRequest="22"
                           HeightRequest="22"
                           HorizontalOptions="Center"/>
                    <Label Text="FINANCEIRO"
                           FontSize="9"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5"
                           TextColor="{Binding SelectedTab, Converter={StaticResource TabTextColorConverter}, ConverterParameter=0}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Acadêmico Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=1}"
                    StrokeThickness="0"
                    Padding="8,16"
                    MinimumHeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="100"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="1"/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=academico}"
                           WidthRequest="22"
                           HeightRequest="22"
                           HorizontalOptions="Center"/>
                    <Label Text="ACADEMIA"
                           FontSize="9"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5"
                           TextColor="{Binding SelectedTab, Converter={StaticResource TabTextColorConverter}, ConverterParameter=1}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Tarefas Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=2}"
                    StrokeThickness="0"
                    Padding="8,16"
                    MinimumHeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="100"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="2"/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=tarefas}"
                           WidthRequest="22"
                           HeightRequest="22"
                           HorizontalOptions="Center"/>
                    <Label Text="TAREFAS"
                           FontSize="9"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5"
                           TextColor="{Binding SelectedTab, Converter={StaticResource TabTextColorConverter}, ConverterParameter=2}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Nutrição Tab -->
            <Border BackgroundColor="{Binding SelectedTab, Converter={StaticResource TabBackgroundConverter}, ConverterParameter=3}"
                    StrokeThickness="0"
                    Padding="8,16"
                    MinimumHeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="100"/>
                </Border.StrokeShape>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectTabCommand}" CommandParameter="3"/>
                </Border.GestureRecognizers>

                <VerticalStackLayout Spacing="4" HorizontalOptions="Center" VerticalOptions="Center">
                    <Image Source="{Binding SelectedTab, Converter={StaticResource TabIconConverter}, ConverterParameter=nutricao}"
                           WidthRequest="22"
                           HeightRequest="22"
                           HorizontalOptions="Center"/>
                    <Label Text="NUTRIÇÃO"
                           FontSize="9"
                           FontAttributes="Bold"
                           CharacterSpacing="0.5"
                           TextColor="{Binding SelectedTab, Converter={StaticResource TabTextColorConverter}, ConverterParameter=3}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

        </FlexLayout>
    </Border>
</ContentView>
