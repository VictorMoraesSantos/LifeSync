<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeSyncApp.Controls.BackNavigationHeader">

    <HorizontalStackLayout x:Name="HeaderLayout"
                           Spacing="6"
                           VerticalOptions="Center">
        <Image Source="arrow_back.svg"
               WidthRequest="20"
               HeightRequest="20"
               VerticalOptions="Center"/>
        <Label x:Name="BackLabel"
               Text="Voltar"
               FontSize="15"
               TextColor="{StaticResource FinDark}"
               VerticalOptions="Center"/>
    </HorizontalStackLayout>

</ContentView>
