<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Nutrition"
             x:Class="LifeSyncApp.Views.Nutrition.ManageMealModal"
             x:DataType="viewmodel:ManageMealViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="#AA000000">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <!-- Bottom Sheet -->
        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="24" Opacity="0.08"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer/>
            </Border.GestureRecognizers>

            <VerticalStackLayout Padding="24,16,24,32" Spacing="24">

                <!-- Drag Handle -->
                <Border BackgroundColor="#E5E4E1"
                        StrokeThickness="0"
                        WidthRequest="40"
                        HeightRequest="4"
                        StrokeShape="RoundRectangle 2"
                        HorizontalOptions="Center"/>

                <!-- Header -->
                <HorizontalStackLayout Spacing="12">
                    <Label Text="✕"
                           FontSize="18"
                           TextColor="#6D6C6A"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                    <Label Text="{Binding Title}"
                           FontSize="18"
                           FontFamily="OutfitSemiBold"
                           TextColor="#1A1918"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Form Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="1"
                        Stroke="#E5E4E1"
                        Padding="20"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="20">

                        <!-- Name Field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Nome *"
                                   FontSize="13"
                                   FontFamily="OutfitSemiBold"
                                   TextColor="#1A1918"/>
                            <Border BackgroundColor="#F5F4F1"
                                    StrokeThickness="1"
                                    Stroke="#E5E4E1"
                                    Padding="16,12"
                                    StrokeShape="RoundRectangle 12">
                                <Entry Text="{Binding Name}"
                                       Placeholder="Ex: Café da manhã"
                                       MaxLength="100"
                                       PlaceholderColor="#9C9B99"
                                       TextColor="#1A1918"
                                       FontSize="15"
                                       FontFamily="OutfitRegular"
                                       BackgroundColor="Transparent"/>
                            </Border>
                            <Label Text="Máximo 100 caracteres"
                                   FontSize="11"
                                   FontFamily="OutfitRegular"
                                   TextColor="#9C9B99"/>
                        </VerticalStackLayout>

                        <!-- Description Field -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Descrição *"
                                   FontSize="13"
                                   FontFamily="OutfitSemiBold"
                                   TextColor="#1A1918"/>
                            <Border BackgroundColor="#F5F4F1"
                                    StrokeThickness="1"
                                    Stroke="#E5E4E1"
                                    Padding="16,12"
                                    HeightRequest="100"
                                    StrokeShape="RoundRectangle 12">
                                <Editor Text="{Binding Description}"
                                        Placeholder="Descreva sua refeição..."
                                        MaxLength="500"
                                        PlaceholderColor="#9C9B99"
                                        TextColor="#1A1918"
                                        FontSize="15"
                                        FontFamily="OutfitRegular"
                                        BackgroundColor="Transparent"
                                        AutoSize="TextChanges"/>
                            </Border>
                            <Label Text="Máximo 500 caracteres"
                                   FontSize="11"
                                   FontFamily="OutfitRegular"
                                   TextColor="#9C9B99"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Buttons -->
                <VerticalStackLayout Spacing="12">
                    <Border BackgroundColor="#3D8A5A"
                            StrokeThickness="0"
                            Padding="0,16"
                            StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="✓"
                                   FontSize="16"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                            <Label Text="{Binding IsEditing, StringFormat='{}{0}'}"
                                   FontSize="16"
                                   FontFamily="OutfitSemiBold"
                                   TextColor="White"
                                   VerticalOptions="Center"
                                   IsVisible="False"/>
                            <Label Text="Criar Refeição"
                                   FontSize="16"
                                   FontFamily="OutfitSemiBold"
                                   TextColor="White"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Text" Value="Salvar Refeição"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                    </Border>

                    <Label Text="Cancelar"
                           FontSize="15"
                           FontFamily="OutfitRegular"
                           TextColor="#6D6C6A"
                           HorizontalOptions="Center"
                           Padding="0,8">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
