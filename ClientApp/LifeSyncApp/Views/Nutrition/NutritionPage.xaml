<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Nutrition"
             xmlns:meal="clr-namespace:LifeSyncApp.DTOs.Nutrition.Meal"
             x:Class="LifeSyncApp.Views.Nutrition.NutritionPage"
             x:DataType="viewmodel:NutritionViewModel"
             x:Name="page"
             BackgroundColor="#F5F4F1">

    <Grid>
        <Grid RowDefinitions="Auto,*">

            <!-- Date Selector -->
            <Grid Grid.Row="0"
                  Padding="24,16"
                  ColumnDefinitions="Auto,*,Auto"
                  HorizontalOptions="Center">
                <Border Grid.Column="0"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PreviousDayCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="‹"
                           FontSize="22"
                           FontFamily="OutfitSemiBold"
                           TextColor="#1A1918"
                           VerticalOptions="Center"/>
                </Border>

                <Label Grid.Column="1"
                       Text="{Binding DateLabel}"
                       FontSize="16"
                       FontFamily="OutfitSemiBold"
                       TextColor="#1A1918"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       Padding="12,0"/>

                <Border Grid.Column="2"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        Padding="8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NextDayCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="›"
                           FontSize="22"
                           FontFamily="OutfitSemiBold"
                           TextColor="#1A1918"
                           VerticalOptions="Center"/>
                </Border>
            </Grid>

            <!-- Scrollable Content -->
            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="24,0,24,24" Spacing="24">

                    <!-- Progress Cards Row -->
                    <Grid ColumnDefinitions="*,12,*" ColumnSpacing="0">

                        <!-- Calories Progress Card -->
                        <Border Grid.Column="0"
                                BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="16"
                                StrokeShape="RoundRectangle 16">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.03"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenDailyProgressCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <!-- Circular Progress Placeholder -->
                                <Grid WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                                    <Border BackgroundColor="Transparent"
                                            StrokeThickness="6"
                                            Stroke="#E5E4E1"
                                            WidthRequest="80"
                                            HeightRequest="80"
                                            StrokeShape="RoundRectangle 40"/>
                                    <ProgressBar Progress="{Binding CaloriesProgressValue}"
                                                 ProgressColor="#3D8A5A"
                                                 IsVisible="False"/>
                                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                                        <Label Text="{Binding CaloriesDisplay}"
                                               FontSize="20"
                                               FontFamily="OutfitSemiBold"
                                               TextColor="#1A1918"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Grid>
                                <Label Text="{Binding CaloriesGoalDisplay}"
                                       FontSize="11"
                                       FontFamily="OutfitRegular"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                                <Label Text="Calorias"
                                       FontSize="13"
                                       FontFamily="OutfitSemiBold"
                                       TextColor="#1A1918"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Hydration Progress Card -->
                        <Border Grid.Column="2"
                                BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="16"
                                StrokeShape="RoundRectangle 16">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.03"/>
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenDailyProgressCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Grid WidthRequest="80" HeightRequest="80" HorizontalOptions="Center">
                                    <Border BackgroundColor="Transparent"
                                            StrokeThickness="6"
                                            Stroke="#E5E4E1"
                                            WidthRequest="80"
                                            HeightRequest="80"
                                            StrokeShape="RoundRectangle 40"/>
                                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                                        <Label Text="{Binding LiquidsDisplay}"
                                               FontSize="20"
                                               FontFamily="OutfitSemiBold"
                                               TextColor="#1A1918"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </Grid>
                                <Label Text="{Binding LiquidsGoalDisplay}"
                                       FontSize="11"
                                       FontFamily="OutfitRegular"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                                <Label Text="Hidratação"
                                       FontSize="13"
                                       FontFamily="OutfitSemiBold"
                                       TextColor="#1A1918"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Diary Summary Row -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                        <Border Grid.Column="0" BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="10,8" StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenDiaryDetailCommand}"/>
                            </Border.GestureRecognizers>
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding CaloriesDisplay}"
                                       FontSize="15"
                                       FontFamily="OutfitSemiBold"
                                       TextColor="#1A1918"
                                       HorizontalOptions="Center"/>
                                <Label Text="kcal"
                                       FontSize="11"
                                       FontFamily="OutfitRegular"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="10,8" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding LiquidsDisplay}"
                                       FontSize="15"
                                       FontFamily="OutfitSemiBold"
                                       TextColor="#1A1918"
                                       HorizontalOptions="Center"/>
                                <Label Text="ml"
                                       FontSize="11"
                                       FontFamily="OutfitRegular"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="10,8" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding MealsCount}"
                                       FontSize="15"
                                       FontFamily="OutfitSemiBold"
                                       TextColor="#1A1918"
                                       HorizontalOptions="Center"/>
                                <Label Text="refeições"
                                       FontSize="11"
                                       FontFamily="OutfitRegular"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="3" BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="10,8" StrokeShape="RoundRectangle 10">
                            <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding LiquidsCount}"
                                       FontSize="15"
                                       FontFamily="OutfitSemiBold"
                                       TextColor="#1A1918"
                                       HorizontalOptions="Center"/>
                                <Label Text="líquidos"
                                       FontSize="11"
                                       FontFamily="OutfitRegular"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Meals Section -->
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Refeições de Hoje"
                               FontSize="16"
                               FontFamily="OutfitSemiBold"
                               TextColor="#1A1918"/>

                        <Label Text="Nenhuma refeição ainda. Toque em '+' para adicionar."
                               FontSize="13"
                               FontFamily="OutfitRegular"
                               TextColor="#9C9B99"
                               HorizontalOptions="Center"
                               Padding="0,12"
                               IsVisible="False">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Meals.Count}" Value="0">
                                    <Setter Property="IsVisible" Value="True"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Meals}" Spacing="8">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="meal:MealDTO">
                                    <Border BackgroundColor="White"
                                            StrokeThickness="1"
                                            Stroke="#E5E4E1"
                                            Padding="16"
                                            StrokeShape="RoundRectangle 16">
                                        <Border.Shadow>
                                            <Shadow Brush="Black" Offset="0,2" Radius="12" Opacity="0.03"/>
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:NutritionViewModel}}, Path=OpenMealDetailCommand}"
                                                CommandParameter="{Binding .}"/>
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                            <!-- Meal Icon -->
                                            <Border Grid.Column="0"
                                                    BackgroundColor="#C8F0D8"
                                                    StrokeThickness="0"
                                                    WidthRequest="44"
                                                    HeightRequest="44"
                                                    VerticalOptions="Center"
                                                    StrokeShape="RoundRectangle 22">
                                                <Label Text="🍽"
                                                       FontSize="20"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Border>

                                            <!-- Meal Info -->
                                            <VerticalStackLayout Grid.Column="1"
                                                                 Spacing="2"
                                                                 VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       FontSize="15"
                                                       FontFamily="OutfitSemiBold"
                                                       TextColor="#1A1918"
                                                       LineBreakMode="TailTruncation"/>
                                                <Label Text="{Binding TotalCalories, StringFormat='{0} kcal'}"
                                                       FontSize="13"
                                                       FontFamily="OutfitRegular"
                                                       TextColor="#6D6C6A"/>
                                            </VerticalStackLayout>

                                            <!-- Arrow -->
                                            <Label Grid.Column="2"
                                                   Text="›"
                                                   FontSize="22"
                                                   TextColor="#9C9B99"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- FAB Button -->
        <Border BackgroundColor="#3D8A5A"
                StrokeThickness="0"
                WidthRequest="56"
                HeightRequest="56"
                StrokeShape="RoundRectangle 28"
                HorizontalOptions="End"
                VerticalOptions="End"
                Margin="0,0,24,24">
            <Border.Shadow>
                <Shadow Brush="#3D8A5A" Offset="0,4" Radius="12" Opacity="0.25"/>
            </Border.Shadow>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenManageMealModalCommand}"/>
            </Border.GestureRecognizers>
            <Image Source="add.svg"
                   WidthRequest="24"
                   HeightRequest="24"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Border>

        <!-- Loading overlay -->
        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#40000000">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Color="#3D8A5A"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
        </Grid>
    </Grid>
</ContentPage>
