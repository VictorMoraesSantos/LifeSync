<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Nutrition"
             xmlns:lt="clr-namespace:LifeSyncApp.DTOs.Nutrition.LiquidType"
             x:Class="LifeSyncApp.Views.Nutrition.ManageLiquidModal"
             x:DataType="viewmodel:ManageLiquidViewModel"
             BackgroundColor="#F5F4F1">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0"
                               Padding="24,16"
                               Spacing="12">
            <Label Text="‹"
                   FontSize="22"
                   FontFamily="OutfitSemiBold"
                   TextColor="#1A1918"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Text="{Binding Title}"
                   FontSize="18"
                   FontFamily="OutfitSemiBold"
                   TextColor="#1A1918"
                   VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="24,0,24,24" Spacing="24">

                <!-- Liquid Type Selection -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Tipo de líquido"
                           FontSize="13"
                           FontFamily="OutfitRegular"
                           TextColor="#6D6C6A"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding LiquidTypes}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="lt:LiquidTypeDTO">
                                <Border Padding="14,12"
                                        StrokeThickness="1"
                                        Stroke="#E5E4E1"
                                        StrokeShape="RoundRectangle 12">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Id}"
                                                     Value="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ManageLiquidViewModel}}, Path=SelectedLiquidTypeId}">
                                            <Setter Property="BackgroundColor" Value="#3D8A5A"/>
                                            <Setter Property="Stroke" Value="#3D8A5A"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ManageLiquidViewModel}}, Path=SelectLiquidTypeCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="10">
                                        <Label Text="💧"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontFamily="OutfitRegular"
                                               TextColor="#1A1918"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Quantity -->
                <VerticalStackLayout Spacing="8">
                    <Label Text="Quantidade (ml)"
                           FontSize="13"
                           FontFamily="OutfitRegular"
                           TextColor="#6D6C6A"/>
                    <Border BackgroundColor="White"
                            StrokeThickness="1"
                            Stroke="#E5E4E1"
                            Padding="16,12"
                            StrokeShape="RoundRectangle 12">
                        <Entry Text="{Binding QuantityText}"
                               Placeholder="250"
                               Keyboard="Numeric"
                               PlaceholderColor="#9C9B99"
                               TextColor="#1A1918"
                               FontSize="16"
                               FontFamily="OutfitRegular"
                               BackgroundColor="Transparent"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Quick Shortcuts -->
                <VerticalStackLayout Spacing="10">
                    <Label Text="Atalhos rápidos"
                           FontSize="13"
                           FontFamily="OutfitRegular"
                           TextColor="#6D6C6A"/>
                    <FlexLayout Wrap="Wrap" JustifyContent="Start" Direction="Row">
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="14,10"
                                Margin="0,0,8,8"
                                StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetQuickQuantityCommand}" CommandParameter="100"/>
                            </Border.GestureRecognizers>
                            <Label Text="100ml" FontSize="13" FontFamily="OutfitRegular" TextColor="#1A1918"/>
                        </Border>
                        <Border BackgroundColor="#3D8A5A"
                                StrokeThickness="0"
                                Padding="14,10"
                                Margin="0,0,8,8"
                                StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetQuickQuantityCommand}" CommandParameter="250"/>
                            </Border.GestureRecognizers>
                            <Label Text="250ml" FontSize="13" FontFamily="OutfitSemiBold" TextColor="White"/>
                        </Border>
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="14,10"
                                Margin="0,0,8,8"
                                StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetQuickQuantityCommand}" CommandParameter="300"/>
                            </Border.GestureRecognizers>
                            <Label Text="300ml" FontSize="13" FontFamily="OutfitRegular" TextColor="#1A1918"/>
                        </Border>
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="14,10"
                                Margin="0,0,8,8"
                                StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetQuickQuantityCommand}" CommandParameter="500"/>
                            </Border.GestureRecognizers>
                            <Label Text="500ml" FontSize="13" FontFamily="OutfitRegular" TextColor="#1A1918"/>
                        </Border>
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="14,10"
                                Margin="0,0,8,8"
                                StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetQuickQuantityCommand}" CommandParameter="1000"/>
                            </Border.GestureRecognizers>
                            <Label Text="1000ml" FontSize="13" FontFamily="OutfitRegular" TextColor="#1A1918"/>
                        </Border>
                        <Border BackgroundColor="White"
                                StrokeThickness="1"
                                Stroke="#E5E4E1"
                                Padding="14,10"
                                Margin="0,0,8,8"
                                StrokeShape="RoundRectangle 10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetQuickQuantityCommand}" CommandParameter="200"/>
                            </Border.GestureRecognizers>
                            <Label Text="200ml" FontSize="13" FontFamily="OutfitRegular" TextColor="#1A1918"/>
                        </Border>
                    </FlexLayout>
                </VerticalStackLayout>

                <!-- Buttons -->
                <VerticalStackLayout Spacing="12">
                    <Border BackgroundColor="#3D8A5A"
                            StrokeThickness="0"
                            Padding="0,16"
                            StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Salvar"
                               FontSize="16"
                               FontFamily="OutfitSemiBold"
                               TextColor="White"
                               HorizontalOptions="Center"/>
                    </Border>

                    <Border BackgroundColor="White"
                            StrokeThickness="1"
                            Stroke="#E5E4E1"
                            Padding="0,16"
                            StrokeShape="RoundRectangle 12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="16"
                               FontFamily="OutfitRegular"
                               TextColor="#6D6C6A"
                               HorizontalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
