<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Nutrition"
             xmlns:food="clr-namespace:LifeSyncApp.DTOs.Nutrition.MealFood"
             x:Class="LifeSyncApp.Views.Nutrition.MealDetailPage"
             x:DataType="viewmodel:MealDetailViewModel"
             x:Name="page"
             BackgroundColor="#F5F4F1"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">

        <!-- Nav Bar -->
        <Grid Grid.Row="0"
              BackgroundColor="#F5F4F1"
              Padding="16,12"
              ColumnDefinitions="Auto,*,Auto,Auto">

            <Border Grid.Column="0"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    Padding="4"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="&#x2190;"
                       FontSize="24"
                       TextColor="#1A1918"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Edit icon -->
            <Border Grid.Column="2"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Padding="8"
                    Margin="0,0,4,0"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenEditMealModalCommand}"/>
                </Border.GestureRecognizers>
                <Image Source="edit.svg" WidthRequest="20" HeightRequest="20"/>
            </Border>

            <!-- Delete icon -->
            <Border Grid.Column="3"
                    BackgroundColor="Transparent"
                    StrokeThickness="0"
                    WidthRequest="36"
                    HeightRequest="36"
                    Padding="8"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteMealCommand}"/>
                </Border.GestureRecognizers>
                <Image Source="trash.svg" WidthRequest="20" HeightRequest="20"/>
            </Border>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="20">

                <!-- Meal Name & Description -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Meal.Name}"
                           FontSize="22"
                           FontFamily="OutfitSemiBold"
                           TextColor="#1A1918"/>

                    <Label Text="{Binding Meal.Description}"
                           FontSize="14"
                           TextColor="#6D6C6A"
                           LineBreakMode="WordWrap">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding Meal.Description}" Value="">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <!-- Green calorie badge -->
                    <Border BackgroundColor="#E8F5E9"
                            Stroke="#3D8A5A"
                            StrokeThickness="1"
                            Padding="12,6"
                            StrokeShape="RoundRectangle 16"
                            HorizontalOptions="Start"
                            Margin="0,4,0,0">
                        <Label Text="{Binding Meal.TotalCalories, StringFormat='{0} kcal total'}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#3D8A5A"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Alimentos Section Header -->
                <Label Text="Alimentos"
                       FontSize="18"
                       FontFamily="OutfitSemiBold"
                       TextColor="#1A1918"
                       Margin="0,4,0,0"/>

                <!-- Foods List (BindableLayout) -->
                <VerticalStackLayout Spacing="10"
                                     BindableLayout.ItemsSource="{Binding Foods}">
                    <BindableLayout.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6" Padding="0,20">
                            <Label Text="Nenhum alimento adicionado"
                                   FontSize="14"
                                   TextColor="#6D6C6A"
                                   HorizontalOptions="Center"/>
                            <Label Text="Toque em '+ Adicionar Alimento' para incluir"
                                   FontSize="12"
                                   TextColor="#A0A0A0"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="food:MealFoodDTO">
                            <Border BackgroundColor="White"
                                    StrokeThickness="1"
                                    Stroke="#E5E4E1"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                        <!-- Food name -->
                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1A1918"/>

                                        <!-- Quantity and calories subtitle -->
                                        <Label FontSize="13" TextColor="#6D6C6A">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Quantity, StringFormat='{0}g'}"/>
                                                    <Span Text=" · "/>
                                                    <Span Text="{Binding TotalCalories, StringFormat='{0} kcal'}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <!-- Colored macros -->
                                        <HorizontalStackLayout Spacing="12" Margin="0,2,0,0">
                                            <Label FontSize="12">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="P: " TextColor="#D4A64A" FontAttributes="Bold"/>
                                                        <Span Text="{Binding Protein, StringFormat='{0}g'}" TextColor="#D4A64A"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label FontSize="12">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="L: " TextColor="#D08068" FontAttributes="Bold"/>
                                                        <Span Text="{Binding Lipids, StringFormat='{0}g'}" TextColor="#D08068"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                            <Label FontSize="12">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="C: " TextColor="#3D8A5A" FontAttributes="Bold"/>
                                                        <Span Text="{Binding Carbohydrates, StringFormat='{0}g'}" TextColor="#3D8A5A"/>
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Edit & Delete icons -->
                                    <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <!-- Edit pencil -->
                                        <Border BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="8"
                                                WidthRequest="36"
                                                HeightRequest="36">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealDetailViewModel}}, Path=OpenEditFoodCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="edit.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>

                                        <!-- Delete trash -->
                                        <Border BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="8"
                                                WidthRequest="36"
                                                HeightRequest="36">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealDetailViewModel}}, Path=DeleteFoodCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="trash.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- + Adicionar Alimento button -->
                <Border BackgroundColor="Transparent"
                        Stroke="#3D8A5A"
                        StrokeThickness="1.5"
                        Padding="0,12"
                        StrokeShape="RoundRectangle 10"
                        HorizontalOptions="Fill">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAddFoodCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="+ Adicionar Alimento"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#3D8A5A"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Resumo Nutricional Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="1"
                        Stroke="#E5E4E1"
                        Padding="16"
                        StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Resumo Nutricional"
                               FontSize="16"
                               FontFamily="OutfitSemiBold"
                               TextColor="#1A1918"/>

                        <BoxView HeightRequest="1" Color="#E5E4E1"/>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <!-- Proteina -->
                            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                <Label Text="Proteína"
                                       FontSize="12"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding TotalProtein, StringFormat='{0}g'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#D4A64A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Lipidios -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                                <Label Text="Lipídios"
                                       FontSize="12"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding TotalLipids, StringFormat='{0}g'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#D08068"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Carboidratos -->
                            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                <Label Text="Carboidratos"
                                       FontSize="12"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"/>
                                <Label Text="{Binding TotalCarbs, StringFormat='{0}g'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#3D8A5A"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Footer buttons -->
                <VerticalStackLayout Spacing="10" Margin="0,8,0,0">
                    <!-- Editar refeicao -->
                    <Border BackgroundColor="Transparent"
                            Stroke="#E5E4E1"
                            StrokeThickness="1.5"
                            Padding="0,14"
                            StrokeShape="RoundRectangle 10"
                            HorizontalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenEditMealModalCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Editar refeição"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#1A1918"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Excluir -->
                    <Border BackgroundColor="Transparent"
                            Stroke="#E5E4E1"
                            StrokeThickness="1.5"
                            Padding="0,14"
                            StrokeShape="RoundRectangle 10"
                            HorizontalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteMealCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Excluir"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#D9534F"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
