<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Nutrition"
             xmlns:food="clr-namespace:LifeSyncApp.Models.Nutrition.MealFood"
             x:Class="LifeSyncApp.Views.Nutrition.MealDetailPage"
             x:DataType="viewmodel:MealDetailViewModel"
             x:Name="page"
             BackgroundColor="#F5F4F1"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*" BackgroundColor="#F5F4F1">

        <!-- Nav Bar -->
        <HorizontalStackLayout Grid.Row="0"
                               Padding="16,12"
                               Spacing="12">
            <Border BackgroundColor="Transparent"
                    StrokeThickness="0"
                    Padding="4"
                    VerticalOptions="Center">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="&#x2190;"
                       FontSize="24"
                       TextColor="#1A1918"
                       VerticalOptions="Center"/>
            </Border>

            <!-- Header skeleton placeholder -->
            <Border HeightRequest="22" WidthRequest="180" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"
                    IsVisible="{Binding IsLoadingMeal}"/>

            <Label Text="{Binding Meal.Name}"
                   FontSize="18"
                   FontFamily="OutfitSemiBold"
                   TextColor="#1A1918"
                   VerticalOptions="Center"
                   IsVisible="{Binding IsLoadingMeal, Converter={StaticResource InvertedBoolConverter}}"/>
        </HorizontalStackLayout>

        <!-- Skeleton Loading -->
        <ScrollView Grid.Row="1"
                    x:Name="SkeletonContainer"
                    IsVisible="{Binding IsLoadingMeal}"
                    BackgroundColor="#F5F4F1">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="20" BackgroundColor="#F5F4F1">

                <!-- Meal Name & Description Skeleton -->
                <VerticalStackLayout Spacing="8">
                    <Border HeightRequest="22" WidthRequest="180" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                    <Border HeightRequest="12" WidthRequest="200" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                    <!-- Calorie badge skeleton -->
                    <HorizontalStackLayout Spacing="6" Margin="0,4,0,0">
                        <Border HeightRequest="16" WidthRequest="16" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0"/>
                        <Border HeightRequest="12" WidthRequest="100" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Nutritional Summary Card Skeleton -->
                <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="16" StrokeShape="RoundRectangle 16">
                    <VerticalStackLayout Spacing="12">
                        <Border HeightRequest="14" WidthRequest="150" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                                <Border HeightRequest="16" WidthRequest="40" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Center"/>
                                <Border HeightRequest="10" WidthRequest="50" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                                <Border HeightRequest="16" WidthRequest="40" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Center"/>
                                <Border HeightRequest="10" WidthRequest="50" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                                <Border HeightRequest="16" WidthRequest="40" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Center"/>
                                <Border HeightRequest="10" WidthRequest="50" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Foods Section Skeleton -->
                <Border HeightRequest="16" WidthRequest="100" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>

                <!-- Add button skeleton -->
                <Border HeightRequest="44" BackgroundColor="Transparent" StrokeThickness="1" Stroke="#EDECEA" StrokeShape="RoundRectangle 10" HorizontalOptions="Fill"/>

                <!-- Food Card Skeleton 1 -->
                <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="14" StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Border HeightRequest="14" WidthRequest="140" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                            <Border HeightRequest="10" WidthRequest="200" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="20" HeightRequest="20" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Food Card Skeleton 2 -->
                <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="14" StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Border HeightRequest="14" WidthRequest="120" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                            <Border HeightRequest="10" WidthRequest="180" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="20" HeightRequest="20" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Food Card Skeleton 3 -->
                <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E5E4E1" Padding="14" StrokeShape="RoundRectangle 12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Border HeightRequest="14" WidthRequest="110" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                            <Border HeightRequest="10" WidthRequest="160" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 5" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" WidthRequest="20" HeightRequest="20" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Action Buttons Skeleton -->
                <VerticalStackLayout Spacing="10" Margin="0,8,0,0">
                    <Border HeightRequest="40" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 10" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Fill"/>
                    <Border HeightRequest="40" BackgroundColor="Transparent" StrokeThickness="1" Stroke="#EDECEA" StrokeShape="RoundRectangle 10" HorizontalOptions="Fill"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Content -->
        <ScrollView Grid.Row="1"
                    IsVisible="{Binding IsLoadingMeal, Converter={StaticResource InvertedBoolConverter}}">
            <VerticalStackLayout Padding="20,8,20,24" Spacing="20">

                <!-- Meal Name & Description -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="{Binding Meal.Name}"
                           FontSize="22"
                           FontFamily="OutfitSemiBold"
                           TextColor="#1A1918"/>

                    <Label Text="{Binding Meal.Description}"
                           FontSize="14"
                           TextColor="#6D6C6A"
                           LineBreakMode="WordWrap">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding Meal.Description}" Value="">
                                <Setter Property="IsVisible" Value="False"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <!-- Green calorie badge -->
                    <Border BackgroundColor="#E8F5E9"
                            Stroke="#3D8A5A"
                            StrokeThickness="1"
                            Padding="12,6"
                            StrokeShape="RoundRectangle 16"
                            HorizontalOptions="Start"
                            Margin="0,4,0,0">
                        <Label Text="{Binding Meal.TotalCalories, StringFormat='{0} kcal total'}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#3D8A5A"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Resumo Nutricional Card -->
                <Border BackgroundColor="White"
                        StrokeThickness="1"
                        Stroke="#E5E4E1"
                        Padding="16"
                        StrokeShape="RoundRectangle 12">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Resumo Nutricional"
                               FontSize="15"
                               FontFamily="OutfitSemiBold"
                               TextColor="#1A1918"/>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                            <!-- Proteina -->
                            <VerticalStackLayout Grid.Column="0" Spacing="2" HorizontalOptions="Center">
                                <Label Text="{Binding TotalProtein, StringFormat='{0}g'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#3D8A5A"
                                       HorizontalOptions="Center"/>
                                <Label Text="Proteína"
                                       FontSize="11"
                                       TextColor="#9C9B99"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Lipidios -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                                <Label Text="{Binding TotalLipids, StringFormat='{0}g'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#D89575"
                                       HorizontalOptions="Center"/>
                                <Label Text="Lipídios"
                                       FontSize="11"
                                       TextColor="#9C9B99"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Carboidratos -->
                            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="Center">
                                <Label Text="{Binding TotalCarbs, StringFormat='{0}g'}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#D4A64A"
                                       HorizontalOptions="Center"/>
                                <Label Text="Carboidratos"
                                       FontSize="11"
                                       TextColor="#9C9B99"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Alimentos Section Header -->
                <Label Text="Alimentos"
                       FontSize="18"
                       FontFamily="OutfitSemiBold"
                       TextColor="#1A1918"
                       Margin="0,4,0,0"/>

                <!-- + Adicionar Alimento button -->
                <Border BackgroundColor="Transparent"
                        Stroke="#3D8A5A"
                        StrokeThickness="1.5"
                        Padding="0,12"
                        StrokeShape="RoundRectangle 10"
                        HorizontalOptions="Fill">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAddFoodCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="+ Adicionar Alimento"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="#3D8A5A"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <!-- Foods List (BindableLayout) -->
                <VerticalStackLayout Spacing="10"
                                     BindableLayout.ItemsSource="{Binding Foods}">
                    <BindableLayout.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="6" Padding="0,20">
                            <Label Text="Nenhum alimento adicionado"
                                   FontSize="14"
                                   TextColor="#6D6C6A"
                                   HorizontalOptions="Center"/>
                            <Label Text="Toque em '+ Adicionar Alimento' para incluir"
                                   FontSize="12"
                                   TextColor="#A0A0A0"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="food:MealFoodDTO">
                            <Border BackgroundColor="White"
                                    StrokeThickness="1"
                                    Stroke="#E5E4E1"
                                    Padding="14"
                                    StrokeShape="RoundRectangle 12">

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                        <!-- Food name -->
                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontAttributes="Bold"
                                               TextColor="#1A1918"/>

                                        <!-- Quantity and calories subtitle -->
                                        <Label FontSize="13" TextColor="#6D6C6A">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding Quantity, StringFormat='{0}g'}"/>
                                                    <Span Text=" · "/>
                                                    <Span Text="{Binding TotalCalories, StringFormat='{0} kcal'}"/>
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>

                                        <!-- Colored macros -->
                                        <HorizontalStackLayout Spacing="12" Margin="0,2,0,0">
                                            <Label Text="{Binding ScaledProtein, StringFormat='P: {0}g'}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#3D8A5A"/>
                                            <Label Text="{Binding ScaledLipids, StringFormat='L: {0}g'}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#D89575"/>
                                            <Label Text="{Binding ScaledCarbohydrates, StringFormat='C: {0}g'}"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="#D4A64A"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Edit & Delete icons -->
                                    <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                        <!-- Edit pencil -->
                                        <Border BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="8"
                                                WidthRequest="36"
                                                HeightRequest="36">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealDetailViewModel}}, Path=OpenEditFoodCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="edit.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>

                                        <!-- Delete trash -->
                                        <Border BackgroundColor="Transparent"
                                                StrokeThickness="0"
                                                Padding="8"
                                                WidthRequest="36"
                                                HeightRequest="36">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MealDetailViewModel}}, Path=DeleteFoodCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="trash.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <!-- Footer buttons -->
                <VerticalStackLayout Spacing="10" Margin="0,8,0,0">
                    <!-- Editar refeicao -->
                    <Border BackgroundColor="Transparent"
                            Stroke="#E5E4E1"
                            StrokeThickness="1.5"
                            Padding="0,14"
                            StrokeShape="RoundRectangle 10"
                            HorizontalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenEditMealModalCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Editar refeição"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#1A1918"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <!-- Excluir -->
                    <Border BackgroundColor="Transparent"
                            Stroke="#E5E4E1"
                            StrokeThickness="1.5"
                            Padding="0,14"
                            StrokeShape="RoundRectangle 10"
                            HorizontalOptions="Fill">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteMealCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Excluir"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#D9534F"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
