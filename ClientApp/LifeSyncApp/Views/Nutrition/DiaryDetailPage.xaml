<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Nutrition"
             xmlns:meal="clr-namespace:LifeSyncApp.Models.Nutrition.Meal"
             xmlns:liquid="clr-namespace:LifeSyncApp.Models.Nutrition.Liquid"
             xmlns:nutconv="clr-namespace:LifeSyncApp.Converters.Nutrition"
             x:Class="LifeSyncApp.Views.Nutrition.DiaryDetailPage"
             x:DataType="viewmodel:DiaryDetailViewModel"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             x:Name="page"
             BackgroundColor="#F5F4F1"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <nutconv:LiquidNameToIconConverter x:Key="LiquidNameToIconConverter"/>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24,0,24,24" Spacing="24">

            <!-- Header -->
            <VerticalStackLayout Spacing="8" Padding="0,12,0,0">
                <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                    <controls:BackNavigationHeader Command="{Binding GoBackCommand}"
                                                   BackText=""/>

                    <Label Text="{Binding DateTitle}"
                           FontSize="22"
                           FontFamily="OutfitSemiBold"
                           TextColor="#1A1918"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <!-- Stats Row -->
                <HorizontalStackLayout Spacing="16">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="🔥" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding CaloriesTotal}"
                               FontSize="14"
                               FontFamily="OutfitRegular"
                               TextColor="#6D6C6A"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="6">
                        <Image Source="water.svg" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"/>
                        <Label Text="{Binding LiquidsTotal}"
                               FontSize="14"
                               FontFamily="OutfitRegular"
                               TextColor="#6D6C6A"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Meals Section -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Refeições"
                       FontSize="18"
                       FontFamily="OutfitSemiBold"
                       TextColor="#1A1918"/>

                <!-- Add Meal Button -->
                <Border BackgroundColor="Transparent"
                        StrokeThickness="1"
                        Stroke="#3D8A5A"
                        HeightRequest="44"
                        StrokeShape="RoundRectangle 12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAddMealCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="+"
                               FontSize="16"
                               FontFamily="OutfitSemiBold"
                               TextColor="#3D8A5A"
                               VerticalOptions="Center"/>
                        <Label Text="Adicionar Refeição"
                               FontSize="14"
                               FontFamily="OutfitSemiBold"
                               TextColor="#3D8A5A"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Meals List -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Meals}" Spacing="10">
                    <BindableLayout.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Padding="0,16">
                            <Label Text="Nenhuma refeição adicionada"
                                   FontSize="14"
                                   FontFamily="OutfitRegular"
                                   TextColor="#6D6C6A"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="meal:MealDTO">
                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 12">
                                <Border.Shadow>
                                    <Shadow Brush="#1A1918" Offset="0,1" Radius="6" Opacity="0.03"/>
                                </Border.Shadow>

                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <!-- Meal Info -->
                                    <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="16"
                                               FontFamily="OutfitSemiBold"
                                               TextColor="#1A1918"/>

                                        <Label Text="{Binding Description}"
                                               FontSize="13"
                                               FontFamily="OutfitRegular"
                                               TextColor="#6D6C6A"
                                               LineBreakMode="TailTruncation">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Description}" Value="">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>

                                        <HorizontalStackLayout Spacing="12" Margin="0,4,0,0">
                                            <Border BackgroundColor="#ECFDF5"
                                                    StrokeThickness="0"
                                                    Padding="8,4"
                                                    StrokeShape="RoundRectangle 6">
                                                <Label Text="{Binding TotalCalories, StringFormat='{0} kcal'}"
                                                       FontSize="12"
                                                       FontFamily="OutfitSemiBold"
                                                       TextColor="#3D8A5A"/>
                                            </Border>

                                            <Label Text="{Binding MealFoods.Count, StringFormat='{0} alimentos'}"
                                                   FontSize="12"
                                                   FontFamily="OutfitRegular"
                                                   TextColor="#6D6C6A"
                                                   VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Action Buttons -->
                                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                        <Border BackgroundColor="#F5F4F1"
                                                StrokeThickness="0"
                                                WidthRequest="34"
                                                HeightRequest="34"
                                                Padding="7"
                                                StrokeShape="RoundRectangle 8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:DiaryDetailViewModel}}, Path=OpenEditMealCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="edit.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>

                                        <Border BackgroundColor="#FEF2F2"
                                                StrokeThickness="0"
                                                WidthRequest="34"
                                                HeightRequest="34"
                                                Padding="7"
                                                StrokeShape="RoundRectangle 8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:DiaryDetailViewModel}}, Path=DeleteMealCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="trash.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Liquids Section -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Líquidos"
                       FontSize="18"
                       FontFamily="OutfitSemiBold"
                       TextColor="#1A1918"/>

                <!-- Add Liquid Button -->
                <Border BackgroundColor="Transparent"
                        StrokeThickness="1"
                        Stroke="#3D8A5A"
                        HeightRequest="44"
                        StrokeShape="RoundRectangle 12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenAddLiquidCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="+"
                               FontSize="16"
                               FontFamily="OutfitSemiBold"
                               TextColor="#3D8A5A"
                               VerticalOptions="Center"/>
                        <Label Text="Adicionar Líquido"
                               FontSize="14"
                               FontFamily="OutfitSemiBold"
                               TextColor="#3D8A5A"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Liquids List -->
                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Liquids}" Spacing="10">
                    <BindableLayout.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Padding="0,16">
                            <Label Text="Nenhum líquido adicionado"
                                   FontSize="14"
                                   FontFamily="OutfitRegular"
                                   TextColor="#6D6C6A"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </BindableLayout.EmptyView>

                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="liquid:LiquidDTO">
                            <Border BackgroundColor="White"
                                    StrokeThickness="0"
                                    Padding="16,12"
                                    StrokeShape="RoundRectangle 12">
                                <Border.Shadow>
                                    <Shadow Brush="#1A1918" Offset="0,1" Radius="6" Opacity="0.03"/>
                                </Border.Shadow>

                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                    <!-- Liquid Icon -->
                                    <Border Grid.Column="0"
                                            BackgroundColor="#C8F0D8"
                                            StrokeThickness="0"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            StrokeShape="RoundRectangle 100"
                                            VerticalOptions="Center">
                                        <Image Source="{Binding Name, Converter={StaticResource LiquidNameToIconConverter}}"
                                               WidthRequest="18"
                                               HeightRequest="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"/>
                                    </Border>

                                    <!-- Liquid Info -->
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontSize="15"
                                               FontFamily="OutfitSemiBold"
                                               TextColor="#1A1918"/>
                                        <Label Text="{Binding Quantity, StringFormat='{0} ml'}"
                                               FontSize="13"
                                               FontFamily="OutfitRegular"
                                               TextColor="#6D6C6A"/>
                                    </VerticalStackLayout>

                                    <!-- Action Buttons -->
                                    <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                        <Border BackgroundColor="#F5F4F1"
                                                StrokeThickness="0"
                                                WidthRequest="34"
                                                HeightRequest="34"
                                                Padding="7"
                                                StrokeShape="RoundRectangle 8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:DiaryDetailViewModel}}, Path=EditLiquidCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="edit.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>

                                        <Border BackgroundColor="#FEF2F2"
                                                StrokeThickness="0"
                                                WidthRequest="34"
                                                HeightRequest="34"
                                                Padding="7"
                                                StrokeShape="RoundRectangle 8">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:DiaryDetailViewModel}}, Path=DeleteLiquidCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Image Source="trash.svg" WidthRequest="18" HeightRequest="18"/>
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Footer Actions -->
            <HorizontalStackLayout Spacing="12"
                                   HorizontalOptions="Center"
                                   Margin="0,12,0,24">
                <!-- Edit Date Button -->
                <Border BackgroundColor="#EDECEA"
                        StrokeThickness="0"
                        Padding="16,0"
                        HeightRequest="40"
                        StrokeShape="RoundRectangle 100">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditDateCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="calendar.svg"
                               WidthRequest="16"
                               HeightRequest="16"
                               VerticalOptions="Center"/>
                        <Label Text="Editar data"
                               FontSize="13"
                               FontFamily="OutfitRegular"
                               FontAttributes="Bold"
                               TextColor="#6D6C6A"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

                <!-- Delete Diary Button -->
                <Border BackgroundColor="Transparent"
                        StrokeThickness="1"
                        Stroke="#D08068"
                        Padding="16,0"
                        HeightRequest="40"
                        StrokeShape="RoundRectangle 100">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DeleteDiaryCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Image Source="trash.svg"
                               WidthRequest="16"
                               HeightRequest="16"
                               VerticalOptions="Center"/>
                        <Label Text="Excluir diário"
                               FontSize="13"
                               FontFamily="OutfitRegular"
                               FontAttributes="Bold"
                               TextColor="#D08068"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
