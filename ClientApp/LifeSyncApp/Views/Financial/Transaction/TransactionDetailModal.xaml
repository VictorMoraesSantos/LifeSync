<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial.Transaction"
             x:Class="LifeSyncApp.Views.Financial.TransactionDetailModal"
             x:DataType="viewmodel:TransactionDetailViewModel"
             Shell.PresentationMode="ModalAnimated"
             BackgroundColor="{StaticResource FinBackground}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Nav Bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              Padding="20,8">

            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="4"
                                   VerticalOptions="Center">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseCommand}"/>
                </HorizontalStackLayout.GestureRecognizers>
                <Image Source="arrow_back.svg"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center"/>
                <Label Text="Voltar"
                       FontSize="15"
                       TextColor="{StaticResource FinDark}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <HorizontalStackLayout Grid.Column="2"
                                   Spacing="16"
                                   VerticalOptions="Center">
                <Image Source="edit.svg"
                       WidthRequest="20"
                       HeightRequest="20">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EditCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
                <Image Source="trash.svg"
                       WidthRequest="20"
                       HeightRequest="20">
                    <Image.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding DeleteCommand}"/>
                    </Image.GestureRecognizers>
                </Image>
            </HorizontalStackLayout>
        </Grid>

        <!-- Content -->
        <ScrollView Grid.Row="1"
                    Padding="20,12,20,20">
            <VerticalStackLayout Spacing="24">

                <!-- Hero Card -->
                <Border BackgroundColor="{StaticResource FinCardBg}"
                        StrokeThickness="1"
                        Stroke="{StaticResource FinBorder}"
                        Padding="20"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12"
                                         HorizontalOptions="Center">

                        <!-- Type Icon Circle -->
                        <Border WidthRequest="48"
                                HeightRequest="48"
                                StrokeShape="RoundRectangle 24"
                                Stroke="Transparent"
                                HorizontalOptions="Center">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding Transaction.TransactionType}"
                                             Value="Income">
                                    <Setter Property="BackgroundColor" Value="#E8F5E9"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding Transaction.TransactionType}"
                                             Value="Expense">
                                    <Setter Property="BackgroundColor" Value="{StaticResource FinDestructiveBg}"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Image WidthRequest="24"
                                   HeightRequest="24"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center">
                                <Image.Triggers>
                                    <DataTrigger TargetType="Image"
                                                 Binding="{Binding Transaction.TransactionType}"
                                                 Value="Income">
                                        <Setter Property="Source" Value="arrow_circle_up.svg"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Image"
                                                 Binding="{Binding Transaction.TransactionType}"
                                                 Value="Expense">
                                        <Setter Property="Source" Value="arrow_circle_down.svg"/>
                                    </DataTrigger>
                                </Image.Triggers>
                            </Image>
                        </Border>

                        <!-- Type Label -->
                        <Label FontSize="13"
                               TextColor="{StaticResource FinMuted}"
                               HorizontalOptions="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding Transaction.TransactionType}"
                                             Value="Income">
                                    <Setter Property="Text" Value="Receita"/>
                                </DataTrigger>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding Transaction.TransactionType}"
                                             Value="Expense">
                                    <Setter Property="Text" Value="Despesa"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <!-- Amount -->
                        <Label FontSize="32"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{Binding Transaction.TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Transaction.TransactionType, Converter={StaticResource TransactionTypeToSignConverter}}"/>
                                    <Span Text="{Binding Transaction.Amount, Converter={StaticResource MoneyToStringConverter}}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>

                        <!-- Description -->
                        <Label Text="{Binding Transaction.Description}"
                               FontSize="16"
                               TextColor="{StaticResource FinDark}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Details Card -->
                <Border BackgroundColor="{StaticResource FinCardBg}"
                        StrokeThickness="1"
                        Stroke="{StaticResource FinBorder}"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>

                    <VerticalStackLayout>

                        <!-- Payment Method Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Método de Pagamento"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6">
                                <Image Source="money_black.svg"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding Transaction.PaymentMethod, Converter={StaticResource PaymentMethodToDisplayConverter}}"
                                       FontSize="14"
                                       TextColor="{StaticResource FinDark}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Date Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Data da Transação"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6">
                                <Image Source="calendar.svg"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding Transaction.TransactionDate, StringFormat='{0:dd} de {0:MMM}. de {0:yyyy}'}"
                                       FontSize="14"
                                       TextColor="{StaticResource FinDark}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Category Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Categoria"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6">
                                <Ellipse WidthRequest="10"
                                         HeightRequest="10"
                                         Fill="{StaticResource FinGreen}"
                                         VerticalOptions="Center"/>
                                <Label Text="{Binding Transaction.Category.Name, TargetNullValue='Sem categoria'}"
                                       FontSize="14"
                                       TextColor="{StaticResource FinDark}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Created Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Criada em"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding Transaction.TransactionDate, StringFormat='{0:dd} de {0:MMM}. de {0:yyyy}'}"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Recurring Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Recorrente"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 8"
                                    StrokeThickness="0"
                                    Padding="10,4"
                                    BackgroundColor="{Binding Transaction.IsRecurring, Converter={StaticResource TransactionTypeToBackgroundConverter}, ConverterParameter=Income}">
                                <Label FontSize="13"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center">
                                    <Label.Triggers>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Transaction.IsRecurring}"
                                                     Value="True">
                                            <Setter Property="Text" Value="Sim"/>
                                            <Setter Property="TextColor" Value="#00A63E"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Transaction.IsRecurring}"
                                                     Value="False">
                                            <Setter Property="Text" Value="Não"/>
                                            <Setter Property="TextColor" Value="{StaticResource FinMuted}"/>
                                        </DataTrigger>
                                    </Label.Triggers>
                                </Label>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Recurrence Details Card -->
                <Border BackgroundColor="{StaticResource FinCardBg}"
                        StrokeThickness="1"
                        Stroke="{StaticResource FinBorder}"
                        StrokeShape="RoundRectangle 16"
                        IsVisible="{Binding HasSchedule}">
                    <Border.Shadow>
                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>

                    <VerticalStackLayout>

                        <!-- Header -->
                        <Label Text="Detalhes da Recorrência"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource FinDark}"
                               Padding="20,16,20,0"/>

                        <!-- Frequency Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Frequência"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding FrequencyDisplay}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource FinDark}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Status Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Status"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding ScheduleStatusDisplay}"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Next Occurrence Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Próxima Ocorrência"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding NextOccurrenceDisplay}"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- Occurrences Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Ocorrências"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding OccurrencesDisplay}"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                        <!-- End Date Row -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,16">
                            <Label Grid.Column="0"
                                   Text="Data Final"
                                   FontSize="13"
                                   TextColor="{StaticResource FinMuted}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1"
                                   Text="{Binding EndDateDisplay}"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Action Buttons -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="12"
              Padding="20,12,20,20">

            <Border Grid.Column="0"
                    HeightRequest="50"
                    StrokeShape="RoundRectangle 14"
                    StrokeThickness="1.5"
                    Stroke="{StaticResource FinDestructiveBorder}"
                    BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding DeleteCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                    <Image Source="trash.svg"
                           WidthRequest="18"
                           HeightRequest="18"/>
                    <Label Text="Excluir"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource FinDestructive}"/>
                </HorizontalStackLayout>
            </Border>

            <Border Grid.Column="1"
                    HeightRequest="50"
                    StrokeShape="RoundRectangle 14"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource FinDark}">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding EditCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="8"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                    <Image Source="edit.svg"
                           WidthRequest="18"
                           HeightRequest="18"/>
                    <Label Text="Editar"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="White"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
