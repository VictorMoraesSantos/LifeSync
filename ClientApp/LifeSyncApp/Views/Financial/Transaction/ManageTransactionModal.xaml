<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial.Transaction"
             xmlns:models="clr-namespace:LifeSyncApp.Models.Financial"
             x:Class="LifeSyncApp.Views.Financial.ManageTransactionModal"
             x:DataType="viewmodel:ManageTransactionViewModel"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="{StaticResource FinDimOverlay}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <!-- Bottom Sheet -->
        <controls:BottomSheet Title="{Binding Title}"
                              CloseCommand="{Binding CancelCommand}">
            <controls:BottomSheet.SheetBody>
            <Grid RowDefinitions="*,Auto">

                <!-- Scrollable Form -->
                <ScrollView Grid.Row="0"
                            MaximumHeightRequest="650">
                    <VerticalStackLayout Padding="24,0,24,24"
                                         Spacing="24">

                        <!-- Transaction Type -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Tipo de Transação"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        HeightRequest="44"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1"
                                        Stroke="{Binding TransactionType, Converter={StaticResource TransactionTypeToBorderConverter}, ConverterParameter=Income}"
                                        BackgroundColor="{Binding TransactionType, Converter={StaticResource TransactionTypeToBackgroundConverter}, ConverterParameter=Income}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetTransactionTypeCommand}"
                                                              CommandParameter="Income"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Image Source="arrow_circle_up.svg"
                                               WidthRequest="18"
                                               HeightRequest="18"/>
                                        <Label Text="Receita"
                                               FontSize="14"
                                               TextColor="{StaticResource FinSecondaryText}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        HeightRequest="44"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1.5"
                                        Stroke="{Binding TransactionType, Converter={StaticResource TransactionTypeToBorderConverter}, ConverterParameter=Expense}"
                                        BackgroundColor="{Binding TransactionType, Converter={StaticResource TransactionTypeToBackgroundConverter}, ConverterParameter=Expense}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetTransactionTypeCommand}"
                                                              CommandParameter="Expense"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Image Source="arrow_circle_down.svg"
                                               WidthRequest="18"
                                               HeightRequest="18"/>
                                        <Label Text="Despesa"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource FinDestructive}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Value -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Valor"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                                <Border Grid.Column="0"
                                        HeightRequest="48"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource FinBackground}"
                                        Padding="14,0">
                                    <Label Text="R$"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource FinDark}"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Border Grid.Column="1"
                                        HeightRequest="48"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource FinBorder}"
                                        BackgroundColor="Transparent"
                                        Padding="14,0">
                                    <Entry Text="{Binding Amount}"
                                           Placeholder="0,00"
                                           Keyboard="Numeric"
                                           PlaceholderColor="{StaticResource FinMuted}"
                                           TextColor="{StaticResource FinDark}"
                                           FontSize="16"
                                           BackgroundColor="Transparent"/>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Description -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Descrição"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Border HeightRequest="48"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="Transparent"
                                    Padding="14,0">
                                <Entry Text="{Binding Description}"
                                       Placeholder="Ex: Almoço no restaurante"
                                       PlaceholderColor="{StaticResource FinMuted}"
                                       TextColor="{StaticResource FinDark}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Category -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Categoria (opcional)"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Border HeightRequest="48"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="Transparent"
                                    Padding="14,0">
                                <Picker ItemsSource="{Binding Categories}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedCategory}"
                                        Title="Selecionar categoria"
                                        TextColor="{StaticResource FinDark}"
                                        FontSize="14"
                                        BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Payment Method -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Método de Pagamento"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>

                            <FlexLayout BindableLayout.ItemsSource="{Binding PaymentMethods}"
                                        Wrap="Wrap"
                                        JustifyContent="Start"
                                        AlignItems="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:SelectablePaymentMethodItem">
                                        <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodBackgroundConverter}}"
                                                StrokeThickness="1"
                                                Stroke="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodBorderConverter}}"
                                                StrokeShape="RoundRectangle 12"
                                                HeightRequest="72"
                                                WidthRequest="108"
                                                Margin="0,0,10,10">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ManageTransactionViewModel}}, Path=TogglePaymentMethodCommand}"
                                                                      CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="6"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Center">
                                                <Image Source="{Binding IconSource}"
                                                       WidthRequest="22"
                                                       HeightRequest="22"/>
                                                <Label Text="{Binding DisplayName}"
                                                       FontSize="11"
                                                       TextColor="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodTextColorConverter}}"
                                                       HorizontalOptions="Center"
                                                       HorizontalTextAlignment="Center"
                                                       MaxLines="2"
                                                       LineBreakMode="WordWrap"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <!-- Date -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Data da Transação"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Border HeightRequest="48"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="Transparent"
                                    Padding="14,0">
                                <DatePicker Date="{Binding TransactionDate}"
                                            TextColor="{StaticResource FinDark}"
                                            FontSize="14"
                                            BackgroundColor="Transparent"
                                            Format="dd/MM/yyyy"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Recurring Toggle -->
                        <VerticalStackLayout Spacing="10"
                                             IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">
                            <Grid ColumnDefinitions="*,Auto"
                                  HeightRequest="44">
                                <Label Grid.Column="0"
                                       Text="Transação Recorrente"
                                       FontSize="14"
                                       TextColor="{StaticResource FinSecondaryText}"
                                       VerticalOptions="Center"/>
                                <Switch Grid.Column="1"
                                        IsToggled="{Binding IsRecurring}"
                                        OnColor="{StaticResource FinGreen}"
                                        VerticalOptions="Center"/>
                            </Grid>

                            <!-- Recurrence Options (visible when IsRecurring = true) -->
                            <VerticalStackLayout Spacing="16"
                                                 IsVisible="{Binding IsRecurring}">

                                <!-- Frequency -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Frequência"
                                           FontSize="14"
                                           TextColor="{StaticResource FinSecondaryText}"/>
                                    <Grid ColumnDefinitions="*,*,*,*"
                                          ColumnSpacing="8">
                                        <Border Grid.Column="0"
                                                HeightRequest="40"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="1"
                                                Stroke="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBorderConverter}, ConverterParameter=Daily}"
                                                BackgroundColor="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBackgroundConverter}, ConverterParameter=Daily}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetFrequencyCommand}"
                                                                      CommandParameter="Daily"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="Diário"
                                                   FontSize="12"
                                                   TextColor="{StaticResource FinSecondaryText}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <Border Grid.Column="1"
                                                HeightRequest="40"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="1"
                                                Stroke="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBorderConverter}, ConverterParameter=Weekly}"
                                                BackgroundColor="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBackgroundConverter}, ConverterParameter=Weekly}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetFrequencyCommand}"
                                                                      CommandParameter="Weekly"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="Semanal"
                                                   FontSize="12"
                                                   TextColor="{StaticResource FinSecondaryText}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <Border Grid.Column="2"
                                                HeightRequest="40"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="1"
                                                Stroke="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBorderConverter}, ConverterParameter=Monthly}"
                                                BackgroundColor="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBackgroundConverter}, ConverterParameter=Monthly}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetFrequencyCommand}"
                                                                      CommandParameter="Monthly"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="Mensal"
                                                   FontSize="12"
                                                   TextColor="{StaticResource FinSecondaryText}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>

                                        <Border Grid.Column="3"
                                                HeightRequest="40"
                                                StrokeShape="RoundRectangle 10"
                                                StrokeThickness="1"
                                                Stroke="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBorderConverter}, ConverterParameter=Yearly}"
                                                BackgroundColor="{Binding SelectedFrequency, Converter={StaticResource FrequencyToBackgroundConverter}, ConverterParameter=Yearly}">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding SetFrequencyCommand}"
                                                                      CommandParameter="Yearly"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="Anual"
                                                   FontSize="12"
                                                   TextColor="{StaticResource FinSecondaryText}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>
                                </VerticalStackLayout>

                                <!-- Recurrence End Date (optional) -->
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="Data Final (opcional)"
                                               FontSize="14"
                                               TextColor="{StaticResource FinSecondaryText}"
                                               VerticalOptions="Center"/>
                                        <Switch Grid.Column="1"
                                                IsToggled="{Binding HasRecurrenceEndDate}"
                                                OnColor="{StaticResource FinGreen}"
                                                VerticalOptions="Center"/>
                                    </Grid>
                                    <Border HeightRequest="48"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1"
                                            Stroke="{StaticResource FinBorder}"
                                            BackgroundColor="Transparent"
                                            Padding="14,0"
                                            IsVisible="{Binding HasRecurrenceEndDate}">
                                        <DatePicker Date="{Binding RecurrenceEndDateValue}"
                                                    TextColor="{StaticResource FinDark}"
                                                    FontSize="14"
                                                    BackgroundColor="Transparent"
                                                    Format="dd/MM/yyyy"/>
                                    </Border>
                                </VerticalStackLayout>

                                <!-- Max Occurrences (optional) -->
                                <VerticalStackLayout Spacing="8">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="Limite de Repetições (opcional)"
                                               FontSize="14"
                                               TextColor="{StaticResource FinSecondaryText}"
                                               VerticalOptions="Center"/>
                                        <Switch Grid.Column="1"
                                                IsToggled="{Binding HasMaxOccurrences}"
                                                OnColor="{StaticResource FinGreen}"
                                                VerticalOptions="Center"/>
                                    </Grid>
                                    <Border HeightRequest="48"
                                            StrokeShape="RoundRectangle 12"
                                            StrokeThickness="1"
                                            Stroke="{StaticResource FinBorder}"
                                            BackgroundColor="Transparent"
                                            Padding="14,0"
                                            IsVisible="{Binding HasMaxOccurrences}">
                                        <Entry Text="{Binding MaxOccurrencesText}"
                                               Placeholder="Ex: 12"
                                               Keyboard="Numeric"
                                               PlaceholderColor="{StaticResource FinMuted}"
                                               TextColor="{StaticResource FinDark}"
                                               FontSize="14"
                                               BackgroundColor="Transparent"/>
                                    </Border>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Action Buttons -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Padding="24,8,24,24">

                    <Border Grid.Column="0"
                            HeightRequest="50"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{StaticResource FinBorder}"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="15"
                               TextColor="{StaticResource FinSecondaryText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            HeightRequest="50"
                            StrokeShape="RoundRectangle 14"
                            Stroke="Transparent"
                            BackgroundColor="{StaticResource FinGreen}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Image Source="add.svg"
                                   WidthRequest="18"
                                   HeightRequest="18"/>
                            <Label Text="{Binding SaveButtonText}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
            </Grid>
            </controls:BottomSheet.SheetBody>
        </controls:BottomSheet>
    </Grid>
</ContentPage>
