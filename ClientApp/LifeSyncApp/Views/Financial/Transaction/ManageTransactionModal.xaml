<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial.Transaction"
             xmlns:models="clr-namespace:LifeSyncApp.Models.Financial"
             x:Class="LifeSyncApp.Views.Financial.ManageTransactionModal"
             x:DataType="viewmodel:ManageTransactionViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="{StaticResource FinDimOverlay}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <!-- Bottom Sheet -->
        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="{StaticResource FinCardBg}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0">
            <Border.Shadow>
                <Shadow Brush="#1A1918" Offset="0,-4" Radius="24" Opacity="0.08"/>
            </Border.Shadow>

            <Border.GestureRecognizers>
                <TapGestureRecognizer/>
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto,Auto,*,Auto">

                <!-- Drag Handle -->
                <HorizontalStackLayout Grid.Row="0"
                                       HorizontalOptions="Center"
                                       Padding="0,12,0,4">
                    <BoxView WidthRequest="40"
                             HeightRequest="4"
                             CornerRadius="2"
                             Color="#D9D9D9"/>
                </HorizontalStackLayout>

                <!-- Sheet Header -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,Auto"
                      Padding="24,16">
                    <Label Grid.Column="0"
                           Text="{Binding ModalTitle}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{StaticResource FinDark}"
                           VerticalOptions="Center"/>
                    <Image Grid.Column="1"
                           Source="close.svg"
                           WidthRequest="24"
                           HeightRequest="24">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Image.GestureRecognizers>
                    </Image>
                </Grid>

                <!-- Scrollable Form -->
                <ScrollView Grid.Row="2"
                            MaximumHeightRequest="550">
                    <VerticalStackLayout Padding="24,0,24,24"
                                         Spacing="24">

                        <!-- Transaction Type -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Tipo de Transação"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Grid ColumnDefinitions="*,*"
                                  ColumnSpacing="12">
                                <Border Grid.Column="0"
                                        HeightRequest="44"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1"
                                        Stroke="{Binding TransactionType, Converter={StaticResource TransactionTypeToBorderConverter}, ConverterParameter=Income}"
                                        BackgroundColor="{Binding TransactionType, Converter={StaticResource TransactionTypeToBackgroundConverter}, ConverterParameter=Income}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetTransactionTypeCommand}"
                                                              CommandParameter="Income"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Image Source="arrow_circle_up.svg"
                                               WidthRequest="18"
                                               HeightRequest="18"/>
                                        <Label Text="Receita"
                                               FontSize="14"
                                               TextColor="{StaticResource FinSecondaryText}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>

                                <Border Grid.Column="1"
                                        HeightRequest="44"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1.5"
                                        Stroke="{Binding TransactionType, Converter={StaticResource TransactionTypeToBorderConverter}, ConverterParameter=Expense}"
                                        BackgroundColor="{Binding TransactionType, Converter={StaticResource TransactionTypeToBackgroundConverter}, ConverterParameter=Expense}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetTransactionTypeCommand}"
                                                              CommandParameter="Expense"/>
                                    </Border.GestureRecognizers>
                                    <HorizontalStackLayout Spacing="8"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center">
                                        <Image Source="arrow_circle_down.svg"
                                               WidthRequest="18"
                                               HeightRequest="18"/>
                                        <Label Text="Despesa"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource FinDestructive}"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Value -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Valor"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Grid ColumnDefinitions="Auto,*"
                                  ColumnSpacing="8">
                                <Border Grid.Column="0"
                                        HeightRequest="48"
                                        StrokeShape="RoundRectangle 12"
                                        Stroke="Transparent"
                                        BackgroundColor="{StaticResource FinBackground}"
                                        Padding="14,0">
                                    <Label Text="R$"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource FinDark}"
                                           VerticalOptions="Center"/>
                                </Border>
                                <Border Grid.Column="1"
                                        HeightRequest="48"
                                        StrokeShape="RoundRectangle 12"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource FinBorder}"
                                        BackgroundColor="Transparent"
                                        Padding="14,0">
                                    <Entry Text="{Binding Amount}"
                                           Placeholder="0,00"
                                           Keyboard="Numeric"
                                           PlaceholderColor="{StaticResource FinMuted}"
                                           TextColor="{StaticResource FinDark}"
                                           FontSize="16"
                                           BackgroundColor="Transparent"/>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Description -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Descrição"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Border HeightRequest="48"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="Transparent"
                                    Padding="14,0">
                                <Entry Text="{Binding Description}"
                                       Placeholder="Ex: Almoço no restaurante"
                                       PlaceholderColor="{StaticResource FinMuted}"
                                       TextColor="{StaticResource FinDark}"
                                       FontSize="14"
                                       BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Category -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Categoria (opcional)"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Border HeightRequest="48"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="Transparent"
                                    Padding="14,0">
                                <Picker ItemsSource="{Binding Categories}"
                                        ItemDisplayBinding="{Binding Name}"
                                        SelectedItem="{Binding SelectedCategory}"
                                        Title="Selecionar categoria"
                                        TextColor="{StaticResource FinDark}"
                                        FontSize="14"
                                        BackgroundColor="Transparent"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Payment Method -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Método de Pagamento"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>

                            <FlexLayout BindableLayout.ItemsSource="{Binding PaymentMethods}"
                                        Wrap="Wrap"
                                        JustifyContent="Start"
                                        AlignItems="Start">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:SelectablePaymentMethodItem">
                                        <Border BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodBackgroundConverter}}"
                                                StrokeThickness="1"
                                                Stroke="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodBorderConverter}}"
                                                StrokeShape="RoundRectangle 12"
                                                HeightRequest="72"
                                                WidthRequest="108"
                                                Margin="0,0,10,10">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ManageTransactionViewModel}}, Path=TogglePaymentMethodCommand}"
                                                                      CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <VerticalStackLayout Spacing="6"
                                                                 HorizontalOptions="Center"
                                                                 VerticalOptions="Center">
                                                <Image Source="{Binding IconSource}"
                                                       WidthRequest="22"
                                                       HeightRequest="22"/>
                                                <Label Text="{Binding DisplayName}"
                                                       FontSize="11"
                                                       TextColor="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodTextColorConverter}}"
                                                       HorizontalOptions="Center"
                                                       HorizontalTextAlignment="Center"
                                                       MaxLines="2"
                                                       LineBreakMode="WordWrap"/>
                                            </VerticalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>

                        <!-- Date -->
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Data da Transação"
                                   FontSize="14"
                                   TextColor="{StaticResource FinSecondaryText}"/>
                            <Border HeightRequest="48"
                                    StrokeShape="RoundRectangle 12"
                                    StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="Transparent"
                                    Padding="14,0">
                                <DatePicker Date="{Binding TransactionDate}"
                                            TextColor="{StaticResource FinDark}"
                                            FontSize="14"
                                            BackgroundColor="Transparent"
                                            Format="dd/MM/yyyy"/>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Action Buttons -->
                <Grid Grid.Row="3"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Padding="24,8,24,24">

                    <Border Grid.Column="0"
                            HeightRequest="50"
                            StrokeShape="RoundRectangle 14"
                            StrokeThickness="1"
                            Stroke="{StaticResource FinBorder}"
                            BackgroundColor="Transparent">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="15"
                               TextColor="{StaticResource FinSecondaryText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            HeightRequest="50"
                            StrokeShape="RoundRectangle 14"
                            Stroke="Transparent"
                            BackgroundColor="{StaticResource FinGreen}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Image Source="add.svg"
                                   WidthRequest="18"
                                   HeightRequest="18"/>
                            <Label Text="Criar"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
