<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial.Transaction"
             xmlns:models="clr-namespace:LifeSyncApp.Models.Financial"
             xmlns:dto="clr-namespace:LifeSyncApp.DTOs.Financial.Transaction"
             x:Class="LifeSyncApp.Views.Financial.TransactionListPage"
             x:DataType="viewmodel:TransactionListViewModel"
             BackgroundColor="{StaticResource FinBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0"
              Padding="20,12"
              ColumnDefinitions="Auto,*,Auto">

            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="6"
                                   VerticalOptions="Center">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                </HorizontalStackLayout.GestureRecognizers>
                <Image Source="arrow_back.svg"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center"/>
                <Label Text="Voltar"
                       FontSize="15"
                       TextColor="{StaticResource FinDark}"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <Border Grid.Column="2"
                    HeightRequest="36"
                    StrokeShape="RoundRectangle 100"
                    Stroke="Transparent"
                    BackgroundColor="{StaticResource FinGreen}"
                    Padding="14,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding OpenManageTransactionModalCommand}"/>
                </Border.GestureRecognizers>
                <HorizontalStackLayout Spacing="6"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                    <Image Source="add.svg"
                           WidthRequest="14"
                           HeightRequest="14"/>
                    <Label Text="Nova"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>
        </Grid>

        <!-- Content -->
        <RefreshView Grid.Row="1"
                     IsRefreshing="{Binding IsBusy}"
                     Command="{Binding RefreshCommand}">
            <ScrollView>
                <VerticalStackLayout Padding="20,0,20,24"
                                     Spacing="20">

                    <!-- Filter Chip -->
                    <HorizontalStackLayout>
                        <Border BackgroundColor="{StaticResource FinCardBg}"
                                StrokeThickness="1"
                                Stroke="{StaticResource FinBorder}"
                                Padding="14,8"
                                StrokeShape="RoundRectangle 100">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenFilterCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="6">
                                <Image Source="filter.svg"
                                       WidthRequest="14"
                                       HeightRequest="14"/>
                                <Label Text="Filtros"
                                       FontSize="13"
                                       TextColor="{StaticResource FinSecondaryText}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </HorizontalStackLayout>

                    <!-- Transaction Groups -->
                    <CollectionView ItemsSource="{Binding GroupedTransactions}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:TransactionGroup">
                                <VerticalStackLayout Spacing="10"
                                                     Margin="0,0,0,10">

                                    <!-- Date Header -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0"
                                               Text="{Binding DateDisplay}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource FinDark}"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding TransactionCountDisplay}"
                                               FontSize="11"
                                               TextColor="{StaticResource FinMuted}"/>
                                    </Grid>

                                    <!-- Transaction Card -->
                                    <Border BackgroundColor="{StaticResource FinCardBg}"
                                            StrokeThickness="1"
                                            Stroke="{StaticResource FinBorder}"
                                            StrokeShape="RoundRectangle 16">
                                        <Border.Shadow>
                                            <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                                        </Border.Shadow>

                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding .}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="dto:TransactionDTO">
                                                    <Grid ColumnDefinitions="Auto,*,Auto"
                                                          ColumnSpacing="12"
                                                          Padding="16,14">
                                                        <Grid.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:TransactionListViewModel}}, Path=OpenDetailCommand}"
                                                                                  CommandParameter="{Binding .}"/>
                                                        </Grid.GestureRecognizers>

                                                        <Ellipse Grid.Column="0"
                                                                 WidthRequest="8"
                                                                 HeightRequest="8"
                                                                 VerticalOptions="Center"
                                                                 Fill="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}"/>

                                                        <VerticalStackLayout Grid.Column="1"
                                                                             Spacing="4"
                                                                             VerticalOptions="Center">
                                                            <Label Text="{Binding Description}"
                                                                   FontSize="14"
                                                                   TextColor="{StaticResource FinDark}"
                                                                   LineBreakMode="TailTruncation"/>
                                                            <HorizontalStackLayout Spacing="6">
                                                                <Border BackgroundColor="{StaticResource FinSurface}"
                                                                        StrokeThickness="0"
                                                                        Padding="8,3"
                                                                        StrokeShape="RoundRectangle 6">
                                                                    <Label Text="{Binding PaymentMethod}"
                                                                           FontSize="11"
                                                                           TextColor="{StaticResource FinSecondaryText}"/>
                                                                </Border>
                                                                <Border BackgroundColor="{StaticResource FinSurface}"
                                                                        StrokeThickness="0"
                                                                        Padding="8,3"
                                                                        StrokeShape="RoundRectangle 6">
                                                                    <Label Text="{Binding Category.Name}"
                                                                           FontSize="11"
                                                                           TextColor="{StaticResource FinSecondaryText}"/>
                                                                </Border>
                                                            </HorizontalStackLayout>
                                                        </VerticalStackLayout>

                                                        <Label Grid.Column="2"
                                                               TextColor="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}"
                                                               FontSize="14"
                                                               FontAttributes="Bold"
                                                               VerticalOptions="Center">
                                                            <Label.FormattedText>
                                                                <FormattedString>
                                                                    <Span Text="{Binding TransactionType, Converter={StaticResource TransactionTypeToSignConverter}}"/>
                                                                    <Span Text="{Binding Amount, Converter={StaticResource MoneyToStringConverter}}"/>
                                                                </FormattedString>
                                                            </Label.FormattedText>
                                                        </Label>
                                                    </Grid>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                    </Border>
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="12"
                                                 Padding="0,40">
                                <Label Text="Nenhuma transação encontrada"
                                       FontSize="16"
                                       TextColor="{StaticResource FinMuted}"
                                       HorizontalOptions="Center"/>
                                <Label Text="Toque em 'Nova' para criar sua primeira transação"
                                       FontSize="14"
                                       TextColor="{StaticResource FinSecondaryText}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>
