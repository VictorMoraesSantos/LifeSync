<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial"
             xmlns:dto="clr-namespace:LifeSyncApp.DTOs.Financial"
             xmlns:transaction="clr-namespace:LifeSyncApp.DTOs.Financial.Transaction"
             xmlns:models="clr-namespace:LifeSyncApp.Models.Financial"
             x:Class="LifeSyncApp.Views.Financial.FinancialPage"
             x:DataType="viewmodel:FinancialViewModel"
             x:Name="page"
             BackgroundColor="{StaticResource FinBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="20,0,20,100"
                             Spacing="24">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="12"
                  Padding="0,12,0,0">

                <Label Grid.Column="0"
                       Text="Financeiro"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="{StaticResource FinDark}"
                       VerticalOptions="Center"/>

                <Border Grid.Column="1"
                        WidthRequest="36"
                        HeightRequest="36"
                        StrokeShape="RoundRectangle 18"
                        Stroke="Transparent"
                        BackgroundColor="Transparent"
                        VerticalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToCategoriesCommand}"/>
                    </Border.GestureRecognizers>
                    <Image Source="category.svg"
                           WidthRequest="22"
                           HeightRequest="22"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Border Grid.Column="2"
                        HeightRequest="36"
                        StrokeShape="RoundRectangle 100"
                        Stroke="Transparent"
                        BackgroundColor="{StaticResource FinGreen}"
                        Padding="14,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenManageTransactionModalCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center">
                        <Image Source="add.svg"
                               WidthRequest="14"
                               HeightRequest="14"/>
                        <Label Text="Nova"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- Balance Card -->
            <Border BackgroundColor="{StaticResource FinDark}"
                    StrokeThickness="0"
                    Padding="20"
                    StrokeShape="RoundRectangle 20">
                <Border.Shadow>
                    <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.08"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding CurrentMonthLabel}"
                           FontSize="13"
                           TextColor="{StaticResource FinMuted}"/>

                    <Label Text="{Binding Balance, StringFormat='R$ {0:N2}'}"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="White"/>

                    <Label Text="{Binding TransactionCount, StringFormat='{0} transações este mês'}"
                           FontSize="12"
                           TextColor="#6D6C6A"/>
                </VerticalStackLayout>
            </Border>

            <!-- Income / Expense Chips (horizontal scroll) -->
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="12">

                    <!-- Receitas Chip -->
                    <Border BackgroundColor="{StaticResource FinCardBg}"
                            StrokeThickness="1"
                            Stroke="{StaticResource FinBorder}"
                            Padding="16,14"
                            WidthRequest="180"
                            StrokeShape="RoundRectangle 16">
                        <Border.Shadow>
                            <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                        </Border.Shadow>
                        <HorizontalStackLayout Spacing="12">
                            <Ellipse Fill="{StaticResource FinGreen}"
                                     WidthRequest="10"
                                     HeightRequest="10"
                                     VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Receitas"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource FinMuted}"/>
                                <Label Text="{Binding TotalIncome, StringFormat='R$ {0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource FinGreen}"/>
                                <Label Text="{Binding IncomeCount, StringFormat='{0} entradas'}"
                                       FontSize="11"
                                       TextColor="{StaticResource FinMuted}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Despesas Chip -->
                    <Border BackgroundColor="{StaticResource FinCardBg}"
                            StrokeThickness="1"
                            Stroke="{StaticResource FinBorder}"
                            Padding="16,14"
                            WidthRequest="180"
                            StrokeShape="RoundRectangle 16">
                        <Border.Shadow>
                            <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                        </Border.Shadow>
                        <HorizontalStackLayout Spacing="12">
                            <Ellipse Fill="{StaticResource FinExpense}"
                                     WidthRequest="10"
                                     HeightRequest="10"
                                     VerticalOptions="Center"/>
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Despesas"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource FinMuted}"/>
                                <Label Text="{Binding TotalExpense, StringFormat='R$ {0:N2}'}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource FinExpense}"/>
                                <Label Text="{Binding ExpenseCount, StringFormat='{0} saídas'}"
                                       FontSize="11"
                                       TextColor="{StaticResource FinMuted}"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                </HorizontalStackLayout>
            </ScrollView>

            <!-- Top Categories (horizontal scroll) -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Top Categorias de Despesas"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource FinDark}"/>

                <!-- Empty state -->
                <Label Text="Nenhuma despesa com categoria este mês"
                       FontSize="13"
                       TextColor="{StaticResource FinMuted}"
                       HorizontalOptions="Center"
                       Margin="0,12"
                       IsVisible="{Binding HasNoTopCategories}"/>

                <!-- Category cards -->
                <ScrollView Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            IsVisible="{Binding HasTopCategories}">
                    <HorizontalStackLayout Spacing="12"
                                           BindableLayout.ItemsSource="{Binding TopCategories}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:CategoryExpense">
                                <Border BackgroundColor="{StaticResource FinCardBg}"
                                        StrokeThickness="1"
                                        Stroke="{StaticResource FinBorder}"
                                        Padding="18,16"
                                        WidthRequest="220"
                                        StrokeShape="RoundRectangle 16">
                                    <Border.Shadow>
                                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.OpenCategoryTransactionsCommand, Source={x:Reference page}}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>

                                    <VerticalStackLayout Spacing="10">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding CategoryName}"
                                                   FontSize="15"
                                                   TextColor="{StaticResource FinDark}"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label Grid.Column="1"
                                                   Text="{Binding Amount, StringFormat='R$ {0:N2}'}"
                                                   FontSize="15"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource FinDark}"/>
                                        </Grid>

                                        <Border BackgroundColor="{StaticResource FinSurface}"
                                                StrokeThickness="0"
                                                HeightRequest="8"
                                                StrokeShape="RoundRectangle 100">
                                            <ProgressBar Progress="{Binding ProgressValue}"
                                                         ProgressColor="{StaticResource FinExpense}"
                                                         BackgroundColor="Transparent"/>
                                        </Border>

                                        <Label Text="{Binding Percentage, StringFormat='{0:F1}% do total de despesas'}"
                                               FontSize="12"
                                               TextColor="{StaticResource FinMuted}"/>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>
            </VerticalStackLayout>

            <!-- Stats Row -->
            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource FinCardBg}"
                        StrokeThickness="1"
                        Stroke="{StaticResource FinBorder}"
                        Padding="18,16"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Maior receita"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="{StaticResource FinMuted}"/>
                        <Label Text="{Binding HighestIncome, StringFormat='R$ {0:N2}'}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource FinGreen}"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource FinCardBg}"
                        StrokeThickness="1"
                        Stroke="{StaticResource FinBorder}"
                        Padding="18,16"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Maior despesa"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="{StaticResource FinMuted}"/>
                        <Label Text="{Binding HighestExpense, StringFormat='R$ {0:N2}'}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource FinExpense}"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Recent Transactions -->
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Transações Recentes"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource FinDark}"/>
                    <Label Grid.Column="1"
                           Text="Ver todas →"
                           FontSize="13"
                           TextColor="{StaticResource FinGreen}">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ViewAllTransactionsCommand}"/>
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Border BackgroundColor="{StaticResource FinCardBg}"
                        StrokeThickness="1"
                        Stroke="{StaticResource FinBorder}"
                        StrokeShape="RoundRectangle 16">
                    <Border.Shadow>
                        <Shadow Brush="#1A1918" Offset="0,2" Radius="12" Opacity="0.03"/>
                    </Border.Shadow>

                    <CollectionView ItemsSource="{Binding RecentTransactions}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="transaction:TransactionDTO">
                                <Grid ColumnDefinitions="Auto,*,Auto"
                                      ColumnSpacing="12"
                                      Padding="16,14">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:FinancialViewModel}}, Path=OpenDetailCommand}"
                                                              CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>

                                    <Ellipse Grid.Column="0"
                                             WidthRequest="8"
                                             HeightRequest="8"
                                             VerticalOptions="Center"
                                             Fill="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}"/>

                                    <VerticalStackLayout Grid.Column="1"
                                                         Spacing="4"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding Description}"
                                               FontSize="14"
                                               TextColor="{StaticResource FinDark}"
                                               LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Spacing="6">
                                            <Border BackgroundColor="{StaticResource FinSurface}"
                                                    StrokeThickness="0"
                                                    Padding="8,3"
                                                    StrokeShape="RoundRectangle 6">
                                                <Label Text="{Binding PaymentMethod}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource FinSecondaryText}"/>
                                            </Border>
                                            <Border BackgroundColor="{StaticResource FinSurface}"
                                                    StrokeThickness="0"
                                                    Padding="8,3"
                                                    StrokeShape="RoundRectangle 6">
                                                <Label Text="{Binding Category.Name}"
                                                       FontSize="11"
                                                       TextColor="{StaticResource FinSecondaryText}"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2"
                                           TextColor="{Binding TransactionType, Converter={StaticResource TransactionTypeToColorConverter}}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding TransactionType, Converter={StaticResource TransactionTypeToSignConverter}}"/>
                                                <Span Text="{Binding Amount, Converter={StaticResource MoneyToStringConverter}}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Border>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
