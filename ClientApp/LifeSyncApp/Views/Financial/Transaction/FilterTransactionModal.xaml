<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial.Transaction"
             xmlns:models="clr-namespace:LifeSyncApp.Models.Financial"
             x:Class="LifeSyncApp.Views.Financial.FilterTransactionModal"
             x:DataType="viewmodel:FilterTransactionViewModel"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             x:Name="page"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="#40000000">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <controls:BottomSheet Title="Filtros"
                              CloseCommand="{Binding CancelCommand}">
            <controls:BottomSheet.SheetBody>
            <Grid RowDefinitions="*,Auto">
                <ScrollView Grid.Row="0">
                    <VerticalStackLayout Padding="20,0,20,20"
                                         Spacing="24">

                        <!-- Tipo de Transação -->
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Tipo de Transação"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource FinDark}"/>

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="#FAFAF8"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout>
                                    <!-- Todas as transações -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedType, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter=''}"
                                            StrokeShape="RoundRectangle 12,12,0,0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}" CommandParameter=""/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Todas as transações"
                                               FontSize="14"
                                               TextColor="{Binding SelectedType, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter=''}"/>
                                    </Border>

                                    <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                                    <!-- Receita -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedType, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter='Income'}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}" CommandParameter="Income"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Receita"
                                               FontSize="14"
                                               TextColor="{Binding SelectedType, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter='Income'}"/>
                                    </Border>

                                    <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                                    <!-- Despesa -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedType, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter='Expense'}"
                                            StrokeShape="RoundRectangle 0,0,12,12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectTypeCommand}" CommandParameter="Expense"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Despesa"
                                               FontSize="14"
                                               TextColor="{Binding SelectedType, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter='Expense'}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Categoria -->
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Categoria"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource FinDark}"/>

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="#FAFAF8"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectableCategories}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:SelectableCategoryItem">
                                            <VerticalStackLayout>
                                                <Border StrokeThickness="0"
                                                        Padding="16,12"
                                                        BackgroundColor="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodBackgroundConverter}}">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer
                                                            Command="{Binding BindingContext.SelectCategoryCommand, Source={x:Reference page}}"
                                                            CommandParameter="{Binding .}"/>
                                                    </Border.GestureRecognizers>
                                                    <Label Text="{Binding Name}"
                                                           FontSize="14"
                                                           TextColor="{Binding IsSelected, Converter={StaticResource BoolToPaymentMethodTextColorConverter}}"/>
                                                </Border>
                                                <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>
                                            </VerticalStackLayout>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Período -->
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Período"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource FinDark}"/>

                            <Border StrokeThickness="1"
                                    Stroke="{StaticResource FinBorder}"
                                    BackgroundColor="#FAFAF8"
                                    StrokeShape="RoundRectangle 12">
                                <VerticalStackLayout>
                                    <!-- Todas as datas -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter=''}"
                                            StrokeShape="RoundRectangle 12,12,0,0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectDateFilterCommand}" CommandParameter=""/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Todas as datas"
                                               FontSize="14"
                                               TextColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter=''}"/>
                                    </Border>

                                    <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                                    <!-- Hoje -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter='Today'}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectDateFilterCommand}" CommandParameter="Today"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Hoje"
                                               FontSize="14"
                                               TextColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter='Today'}"/>
                                    </Border>

                                    <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                                    <!-- Esta semana -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter='ThisWeek'}">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectDateFilterCommand}" CommandParameter="ThisWeek"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Esta semana"
                                               FontSize="14"
                                               TextColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter='ThisWeek'}"/>
                                    </Border>

                                    <BoxView HeightRequest="1" Color="{StaticResource FinBorder}"/>

                                    <!-- Este mês -->
                                    <Border StrokeThickness="0"
                                            Padding="16,12"
                                            BackgroundColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToBackgroundConverter}, ConverterParameter='ThisMonth'}"
                                            StrokeShape="RoundRectangle 0,0,12,12">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectDateFilterCommand}" CommandParameter="ThisMonth"/>
                                        </Border.GestureRecognizers>
                                        <Label Text="Este mês"
                                               FontSize="14"
                                               TextColor="{Binding SelectedDateFilter, Converter={StaticResource StringEqualToTextColorConverter}, ConverterParameter='ThisMonth'}"/>
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>

                <!-- Action Buttons -->
                <Grid Grid.Row="1"
                      ColumnDefinitions="*,*"
                      ColumnSpacing="12"
                      Padding="20,12,20,24">

                    <Border Grid.Column="0"
                            HeightRequest="48"
                            StrokeShape="RoundRectangle 100"
                            StrokeThickness="1"
                            Stroke="{StaticResource FinBorder}"
                            BackgroundColor="{StaticResource FinCardBg}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ClearCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Limpar tudo"
                               FontSize="14"
                               TextColor="{StaticResource FinSecondaryText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            HeightRequest="48"
                            StrokeShape="RoundRectangle 100"
                            Stroke="Transparent"
                            BackgroundColor="{StaticResource FinGreen}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ApplyCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Aplicar filtros"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>
                </Grid>
            </Grid>
            </controls:BottomSheet.SheetBody>
        </controls:BottomSheet>
    </Grid>
</ContentPage>
