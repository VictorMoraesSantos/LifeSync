<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:LifeSyncApp.ViewModels.Financial.Category"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             x:Class="LifeSyncApp.Views.Financial.ManageCategoryModal"
             x:DataType="viewmodel:ManageCategoryViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="{StaticResource FinDimOverlay}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <controls:BottomSheet Title="{Binding Title}"
                              CloseCommand="{Binding CancelCommand}">
            <controls:BottomSheet.SheetBody>
            <VerticalStackLayout Padding="24,20,24,24" Spacing="20">

                <controls:FormEntry LabelText="Nome da Categoria"
                                    Placeholder="Ex: Alimentação, Transporte, Saúde..."
                                    Text="{Binding Name}"/>

                <controls:FormEntry LabelText="Descrição (opcional)"
                                    Placeholder="Ex: Gastos com supermercado, restaurantes e..."
                                    Text="{Binding CategoryDescription}"/>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            HeightRequest="48"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{StaticResource FinBorder}"
                            BackgroundColor="{StaticResource FinCardBg}"
                            Padding="24,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="Cancelar"
                               FontSize="15"
                               TextColor="{StaticResource FinSecondaryText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                    </Border>

                    <Border Grid.Column="1"
                            HeightRequest="48"
                            StrokeShape="RoundRectangle 12"
                            Stroke="Transparent"
                            BackgroundColor="{StaticResource FinGreen}"
                            Padding="24,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Image Source="add.svg"
                                   WidthRequest="18"
                                   HeightRequest="18"/>
                            <Label Text="{Binding ActionButtonText}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
            </controls:BottomSheet.SheetBody>
        </controls:BottomSheet>
    </Grid>
</ContentPage>
