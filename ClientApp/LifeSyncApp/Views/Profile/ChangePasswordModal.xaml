<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.Profile"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             x:Class="LifeSyncApp.Views.Profile.ChangePasswordModal"
             x:DataType="viewmodels:ChangePasswordViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="{StaticResource FinDimOverlay}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <controls:BottomSheet Title="Alterar Senha"
                              CloseCommand="{Binding CancelCommand}">
            <controls:BottomSheet.SheetBody>
            <VerticalStackLayout Spacing="20" Padding="20,0,20,20">

                <Label Text="Por segurança, informe sua senha atual e defina a nova senha."
                       FontFamily="OutfitRegular"
                       FontSize="13"
                       TextColor="#6D6C6A"/>

                <controls:FormEntry LabelText="Senha atual"
                                    Placeholder="Digite sua senha atual"
                                    Text="{Binding CurrentPassword}"
                                    IsPassword="True"/>

                <controls:FormEntry LabelText="Nova senha"
                                    Placeholder="Digite a nova senha"
                                    Text="{Binding NewPassword}"
                                    IsPassword="True"/>

                <controls:FormEntry LabelText="Confirmar nova senha"
                                    Placeholder="Confirme a nova senha"
                                    Text="{Binding ConfirmPassword}"
                                    IsPassword="True"/>

                <controls:ModalButtonBar CancelCommand="{Binding CancelCommand}"
                                         SaveCommand="{Binding SaveCommand}"/>

            </VerticalStackLayout>
            </controls:BottomSheet.SheetBody>
        </controls:BottomSheet>
    </Grid>
</ContentPage>
