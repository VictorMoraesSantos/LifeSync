<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.Profile"
             x:Class="LifeSyncApp.Views.Profile.ChangePasswordModal"
             x:DataType="viewmodels:ChangePasswordViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="{StaticResource FinDimOverlay}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="{StaticResource FinCardBg}"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24,24,0,0">
            <Border.Shadow>
                <Shadow Brush="#1A1918" Offset="0,-4" Radius="24" Opacity="0.08"/>
            </Border.Shadow>

            <Border.GestureRecognizers>
                <TapGestureRecognizer/>
            </Border.GestureRecognizers>

            <VerticalStackLayout Spacing="0">

                <!-- Drag Handle -->
                <HorizontalStackLayout HorizontalOptions="Center" Padding="0,12,0,4">
                    <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="100" Color="#D1D0CD"/>
                </HorizontalStackLayout>

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto" Padding="20,16">
                    <Label Text="Alterar Senha"
                           FontFamily="OutfitSemiBold"
                           FontSize="18"
                           TextColor="#1A1918"
                           VerticalOptions="Center"/>
                    <ImageButton Grid.Column="1"
                                 Source="close.svg"
                                 BackgroundColor="Transparent"
                                 Padding="8"
                                 Command="{Binding CancelCommand}"/>
                </Grid>

                <!-- Form Content -->
                <VerticalStackLayout Spacing="20" Padding="20,0,20,20">

                    <!-- Info Text -->
                    <Label Text="Por segurança, informe sua senha atual e defina a nova senha."
                           FontFamily="OutfitRegular"
                           FontSize="13"
                           TextColor="#6D6C6A"/>

                    <!-- Senha atual -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Senha atual"
                               FontFamily="OutfitSemiBold"
                               FontSize="14"
                               TextColor="#1A1918"/>
                        <Border Stroke="#E5E4E1"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#FAFAF8"
                                HeightRequest="44">
                            <Entry Placeholder="Digite sua senha atual"
                                   PlaceholderColor="#9C9B99"
                                   Text="{Binding CurrentPassword}"
                                   IsPassword="True"
                                   FontFamily="OutfitRegular"
                                   FontSize="14"
                                   TextColor="#1A1918"
                                   BackgroundColor="Transparent"
                                   Margin="16,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Nova senha -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Nova senha"
                               FontFamily="OutfitSemiBold"
                               FontSize="14"
                               TextColor="#1A1918"/>
                        <Border Stroke="#E5E4E1"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#FAFAF8"
                                HeightRequest="44">
                            <Entry Placeholder="Digite a nova senha"
                                   PlaceholderColor="#9C9B99"
                                   Text="{Binding NewPassword}"
                                   IsPassword="True"
                                   FontFamily="OutfitRegular"
                                   FontSize="14"
                                   TextColor="#1A1918"
                                   BackgroundColor="Transparent"
                                   Margin="16,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Confirmar nova senha -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Confirmar nova senha"
                               FontFamily="OutfitSemiBold"
                               FontSize="14"
                               TextColor="#1A1918"/>
                        <Border Stroke="#E5E4E1"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 12"
                                BackgroundColor="#FAFAF8"
                                HeightRequest="44">
                            <Entry Placeholder="Confirme a nova senha"
                                   PlaceholderColor="#9C9B99"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   FontFamily="OutfitRegular"
                                   FontSize="14"
                                   TextColor="#1A1918"
                                   BackgroundColor="Transparent"
                                   Margin="16,0"/>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Action Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 100"
                                Stroke="#E5E4E1"
                                StrokeThickness="1"
                                BackgroundColor="White"
                                HeightRequest="50">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding CancelCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="Cancelar"
                                   FontFamily="OutfitRegular"
                                   FontSize="14"
                                   TextColor="#6D6C6A"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>

                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 100"
                                StrokeThickness="0"
                                BackgroundColor="#3D8A5A"
                                HeightRequest="50">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SaveCommand}"/>
                            </Border.GestureRecognizers>
                            <Border.Triggers>
                                <DataTrigger TargetType="Border"
                                             Binding="{Binding IsBusy}"
                                             Value="True">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </DataTrigger>
                            </Border.Triggers>
                            <Label Text="Salvar"
                                   FontFamily="OutfitSemiBold"
                                   FontSize="14"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"/>
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
