<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.Profile"
             xmlns:controls="clr-namespace:LifeSyncApp.Controls"
             x:Class="LifeSyncApp.Views.Profile.ChangeEmailModal"
             x:DataType="viewmodels:ChangeEmailViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="{StaticResource FinDimOverlay}">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CancelCommand}"/>
        </Grid.GestureRecognizers>

        <controls:BottomSheet Title="Alterar Email"
                              CloseCommand="{Binding CancelCommand}">
            <controls:BottomSheet.SheetBody>
            <VerticalStackLayout Spacing="20" Padding="20,0,20,20">

                <Label Text="Informe o novo email e confirme com sua senha."
                       FontFamily="OutfitRegular"
                       FontSize="13"
                       TextColor="#6D6C6A"/>

                <controls:FormEntry LabelText="Novo Email"
                                    Placeholder="seu@email.com"
                                    Text="{Binding NewEmail}"
                                    Keyboard="Email"/>

                <controls:FormEntry LabelText="Senha atual"
                                    Placeholder="Digite sua senha"
                                    Text="{Binding CurrentPassword}"
                                    IsPassword="True"/>

                <controls:ModalButtonBar CancelCommand="{Binding CancelCommand}"
                                         SaveCommand="{Binding SaveCommand}"/>

            </VerticalStackLayout>
            </controls:BottomSheet.SheetBody>
        </controls:BottomSheet>
    </Grid>
</ContentPage>
