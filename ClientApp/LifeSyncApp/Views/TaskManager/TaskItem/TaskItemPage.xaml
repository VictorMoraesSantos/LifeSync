<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeSyncApp.Views.TaskManager.TaskItem.TaskItemPage"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.TaskManager"
             xmlns:models="clr-namespace:LifeSyncApp.Models.TaskManager"
             xmlns:enums="clr-namespace:LifeSyncApp.Models.TaskManager.Enums"
             x:DataType="viewmodels:TaskItemsViewModel"
             Title=""
             BackgroundColor="#F5F4F1">

    <Grid>
        <Grid RowDefinitions="Auto,*">

            <!-- Header -->
            <Grid Grid.Row="0"
                  Padding="20,12"
                  BackgroundColor="#F5F4F1"
                  ColumnDefinitions="*,Auto,Auto">

                <Label Text="Tarefas"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#1A1918"
                       VerticalOptions="Center"/>

                <Border Grid.Column="1"
                        WidthRequest="44"
                        HeightRequest="44"
                        StrokeShape="RoundRectangle 22"
                        Stroke="Transparent"
                        BackgroundColor="Transparent"
                        Margin="0,0,12,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToLabelsCommand}"/>
                    </Border.GestureRecognizers>
                    <Image Source="label.svg"
                           WidthRequest="22"
                           HeightRequest="22"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                </Border>

                <Border Grid.Column="2"
                        HeightRequest="40"
                        StrokeShape="RoundRectangle 20"
                        Stroke="Transparent"
                        BackgroundColor="#3D8A5A">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding OpenManageTaskModalCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout Spacing="6"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Padding="16,0">
                        <Image Source="add.svg"
                               WidthRequest="16"
                               HeightRequest="16"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"/>
                        <Label Text="Nova"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="White"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
            </Grid>

            <!-- Task List -->
            <CollectionView Grid.Row="1"
                            ItemsSource="{Binding GroupedTasks}"
                            IsGrouped="True"
                            SelectionMode="None">

                <CollectionView.Header>
                    <VerticalStackLayout Padding="20,16,20,0">
                        <Border Padding="14,8"
                                StrokeShape="RoundRectangle 100"
                                Stroke="#E5E4E1"
                                StrokeThickness="1"
                                BackgroundColor="White"
                                HorizontalOptions="Start">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding OpenFiltersCommand}" />
                            </Border.GestureRecognizers>

                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Image Source="filter.svg"
                                       WidthRequest="16"
                                       HeightRequest="16"
                                       VerticalOptions="Center" />
                                <Label Text="Filtros"
                                       FontSize="14"
                                       TextColor="#6D6C6A"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </CollectionView.Header>

                <CollectionView.EmptyView>
                    <StackLayout Padding="20"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center">
                        <Label Text="Nenhuma tarefa encontrada"
                               FontSize="16"
                               HorizontalTextAlignment="Center"
                               TextColor="#9C9B99" />
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="models:TaskGroup">
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="20,24,20,8">
                            <Label Text="{Binding DisplayDate}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsOverdue}"
                                                 Value="True">
                                        <Setter Property="TextColor" Value="#D08068"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding IsOverdue}"
                                                 Value="False">
                                        <Setter Property="TextColor" Value="#1A1918"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>

                            <Label Grid.Column="1"
                                   Text="{Binding TaskCountText}"
                                   FontSize="12"
                                   TextColor="#9C9B99"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:TaskItem">

                        <Border Margin="20,0,20,8"
                                Padding="16"
                                StrokeShape="RoundRectangle 16"
                                Stroke="#E5E4E1"
                                StrokeThickness="1"
                                BackgroundColor="White">
                            <Border.Shadow>
                                <Shadow Brush="#1A191808"
                                        Offset="0,2"
                                        Radius="12"
                                        Opacity="1"/>
                            </Border.Shadow>

                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TaskItemsViewModel}}, Path=ViewTaskDetailCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <!-- Checkbox -->
                                <Grid Grid.Column="0"
                                      WidthRequest="22"
                                      HeightRequest="22"
                                      VerticalOptions="Start"
                                      Margin="0,2,0,0">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TaskItemsViewModel}}, Path=ToggleStatusCommand}"
                                                              CommandParameter="{Binding .}"/>
                                    </Grid.GestureRecognizers>
                                    <Ellipse WidthRequest="22"
                                             HeightRequest="22"
                                             Fill="White"
                                             Stroke="#D1D0CD"
                                             StrokeThickness="2">
                                        <Ellipse.Triggers>
                                            <DataTrigger TargetType="Ellipse"
                                                         Binding="{Binding Status}"
                                                         Value="{x:Static enums:Status.Completed}">
                                                <Setter Property="Fill" Value="#3D8A5A"/>
                                                <Setter Property="Stroke" Value="#3D8A5A"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Ellipse"
                                                         Binding="{Binding Status}"
                                                         Value="{x:Static enums:Status.InProgress}">
                                                <Setter Property="Stroke" Value="#D4A64A"/>
                                                <Setter Property="Fill" Value="#FFF8E8"/>
                                            </DataTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>
                                    <Label Text="{Binding Status, Converter={StaticResource StatusToIconConverter}}"
                                           FontSize="12"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           VerticalTextAlignment="Center"
                                           TextColor="{Binding Status, Converter={StaticResource StatusToColorConverter}}"/>
                                </Grid>

                                <!-- Card Body -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <!-- Title -->
                                    <Label Text="{Binding Title}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#1A1918"
                                           VerticalTextAlignment="Center"
                                           LineBreakMode="TailTruncation">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding Status}"
                                                         Value="{x:Static enums:Status.Completed}">
                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                <Setter Property="TextColor" Value="#9C9B99"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>

                                    <!-- Labels -->
                                    <FlexLayout Wrap="Wrap"
                                                JustifyContent="Start"
                                                AlignItems="Center"
                                                BindableLayout.ItemsSource="{Binding Labels}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:TaskLabel">
                                                <Border Padding="8,4"
                                                        StrokeShape="RoundRectangle 6"
                                                        StrokeThickness="0"
                                                        BackgroundColor="{Binding LabelColor, Converter={StaticResource LabelColorToLightColorConverter}}"
                                                        Margin="0,0,6,0">
                                                    <HorizontalStackLayout Spacing="4">
                                                        <Ellipse WidthRequest="8"
                                                                 HeightRequest="8"
                                                                 Fill="{Binding LabelColor, Converter={StaticResource LabelColorToConverter}}"
                                                                 VerticalOptions="Center"/>
                                                        <Label Text="{Binding Name}"
                                                               FontSize="12"
                                                               TextColor="#1A1918"
                                                               VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>
                                </VerticalStackLayout>

                                <!-- Priority -->
                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 100"
                                        StrokeThickness="0"
                                        Padding="10,4"
                                        VerticalOptions="Start"
                                        Margin="0,2,0,0">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Priority}"
                                                     Value="{x:Static enums:Priority.Low}">
                                            <Setter Property="BackgroundColor" Value="#E8F5E9"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Priority}"
                                                     Value="{x:Static enums:Priority.Medium}">
                                            <Setter Property="BackgroundColor" Value="#FFF3E0"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Priority}"
                                                     Value="{x:Static enums:Priority.High}">
                                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding Priority}"
                                                     Value="{x:Static enums:Priority.Urgent}">
                                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Label Text="{Binding Priority}"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{Binding Priority, Converter={StaticResource PriorityToColorConverter}}"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
