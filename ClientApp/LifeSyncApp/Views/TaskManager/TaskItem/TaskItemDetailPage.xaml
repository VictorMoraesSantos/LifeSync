<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:enums="clr-namespace:LifeSyncApp.Models.TaskManager.Enums"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.TaskManager"
             xmlns:models="clr-namespace:LifeSyncApp.Models.TaskManager"
             x:Class="LifeSyncApp.Views.TaskManager.TaskItem.TaskItemDetailPage"
             x:DataType="viewmodels:TaskItemsViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F4F1">

    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="0">

        <!-- Nav Bar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto,Auto"
              Padding="20,8"
              BackgroundColor="#F5F4F1">
            <HorizontalStackLayout Grid.Column="0"
                                   Spacing="4"
                                   VerticalOptions="Center">
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </HorizontalStackLayout.GestureRecognizers>

                <Image Source="arrow_back.svg"
                       WidthRequest="20"
                       HeightRequest="20"
                       VerticalOptions="Center"/>

                <Label Text="Voltar"
                       TextColor="#1A1918"
                       FontSize="15"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <ImageButton Grid.Column="2"
                         Source="edit.svg"
                         BackgroundColor="Transparent"
                         WidthRequest="36"
                         HeightRequest="36"
                         Padding="8"
                         Command="{Binding EditTaskCommand}"/>

            <ImageButton Grid.Column="3"
                         Source="trash.svg"
                         BackgroundColor="Transparent"
                         WidthRequest="36"
                         HeightRequest="36"
                         Padding="8"
                         Command="{Binding DeleteTaskCommand}"/>
        </Grid>

        <!-- Detail Content -->
        <ScrollView Grid.Row="1" Padding="20,16,20,20">
            <VerticalStackLayout Spacing="24">

                <!-- Title -->
                <Label Text="{Binding SelectedTask.Title}"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1A1918"
                       LineBreakMode="WordWrap"/>

                <!-- Description -->
                <Label Text="{Binding SelectedTask.Description}"
                       FontSize="15"
                       TextColor="#6D6C6A"
                       LineBreakMode="WordWrap"
                       LineHeight="1.5"/>

                <!-- Fields Card -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E5E4E1"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="0">
                    <Border.Shadow>
                        <Shadow Brush="#1A191808"
                                Offset="0,2"
                                Radius="12"
                                Opacity="1"/>
                    </Border.Shadow>

                    <VerticalStackLayout>
                        <!-- Status -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="16,14">
                            <Label Text="Status"
                                   FontSize="14"
                                   TextColor="#9C9B99"
                                   VerticalOptions="Center"/>

                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Ellipse WidthRequest="8"
                                         HeightRequest="8"
                                         Fill="{Binding SelectedTask.Status, Converter={StaticResource StatusToColorConverter}}"
                                         VerticalOptions="Center"/>
                                <Label Text="{Binding SelectedTask.Status}"
                                       FontSize="14"
                                       TextColor="#1A1918"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E5E4E1"/>

                        <!-- Priority -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="16,14">
                            <Label Text="Prioridade"
                                   FontSize="14"
                                   TextColor="#9C9B99"
                                   VerticalOptions="Center"/>

                            <Border Grid.Column="1"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 100"
                                    Padding="10,4"
                                    VerticalOptions="Center">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding SelectedTask.Priority}"
                                                 Value="{x:Static enums:Priority.Low}">
                                        <Setter Property="BackgroundColor" Value="#E8F5E9"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding SelectedTask.Priority}"
                                                 Value="{x:Static enums:Priority.Medium}">
                                        <Setter Property="BackgroundColor" Value="#FFF3E0"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding SelectedTask.Priority}"
                                                 Value="{x:Static enums:Priority.High}">
                                        <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding SelectedTask.Priority}"
                                                 Value="{x:Static enums:Priority.Urgent}">
                                        <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding SelectedTask.Priority}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{Binding SelectedTask.Priority, Converter={StaticResource PriorityToColorConverter}}"/>
                            </Border>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E5E4E1"/>

                        <!-- Due Date -->
                        <Grid ColumnDefinitions="*,Auto"
                              Padding="16,14">
                            <Label Text="Vencimento"
                                   FontSize="14"
                                   TextColor="#9C9B99"
                                   VerticalOptions="Center"/>

                            <HorizontalStackLayout Grid.Column="1"
                                                   Spacing="6"
                                                   VerticalOptions="Center">
                                <Image Source="calendar.svg"
                                       WidthRequest="14"
                                       HeightRequest="14"
                                       VerticalOptions="Center"/>
                                <Label Text="{Binding SelectedTask.DueDate}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="#3D8A5A"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Grid>
                        <BoxView HeightRequest="1" Color="#E5E4E1"/>

                        <!-- Labels -->
                        <VerticalStackLayout Padding="16,14"
                                             Spacing="10">
                            <Label Text="Etiquetas"
                                   FontSize="14"
                                   TextColor="#9C9B99"/>

                            <FlexLayout Wrap="Wrap"
                                        JustifyContent="Start"
                                        AlignItems="Center"
                                        AlignContent="Start"
                                        BindableLayout.ItemsSource="{Binding SelectedTask.Labels}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:TaskLabel">
                                        <Border StrokeThickness="0"
                                                StrokeShape="RoundRectangle 6"
                                                Padding="8,4"
                                                BackgroundColor="{Binding LabelColor, Converter={StaticResource LabelColorToLightColorConverter}}"
                                                Margin="0,0,6,6">
                                            <HorizontalStackLayout Spacing="4">
                                                <Ellipse WidthRequest="8"
                                                         HeightRequest="8"
                                                         Fill="{Binding LabelColor, Converter={StaticResource LabelColorToConverter}}"
                                                         VerticalOptions="Center"/>
                                                <Label Text="{Binding Name}"
                                                       FontSize="12"
                                                       TextColor="#1A1918"
                                                       VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                                <BindableLayout.EmptyViewTemplate>
                                    <DataTemplate>
                                        <Label Text="Nenhuma etiqueta"
                                               FontSize="12"
                                               TextColor="#9C9B99"/>
                                    </DataTemplate>
                                </BindableLayout.EmptyViewTemplate>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <!-- Timestamps -->
                <VerticalStackLayout Spacing="8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Criada em"
                               FontSize="13"
                               TextColor="#9C9B99"/>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedTask.CreatedAt}"
                               FontSize="13"
                               TextColor="#6D6C6A"/>
                    </Grid>
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Atualizada em"
                               FontSize="13"
                               TextColor="#9C9B99"/>
                        <Label Grid.Column="1"
                               Text="{Binding SelectedTask.UpdatedAt}"
                               FontSize="13"
                               TextColor="#6D6C6A"/>
                    </Grid>
                </VerticalStackLayout>

                <!-- Action Buttons -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 100"
                            Stroke="#D08068"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="12,12"
                            HeightRequest="48">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding DeleteTaskCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Image Source="trash.svg"
                                   WidthRequest="16"
                                   HeightRequest="16"/>
                            <Label Text="Excluir"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#D08068"/>
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 100"
                            StrokeThickness="0"
                            BackgroundColor="#1A1918"
                            Padding="12,12"
                            HeightRequest="48">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EditTaskCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="6"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Image Source="edit.svg"
                                   WidthRequest="16"
                                   HeightRequest="16"/>
                            <Label Text="Editar"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="White"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
