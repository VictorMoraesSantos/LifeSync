<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.TaskManager"
             xmlns:models="clr-namespace:LifeSyncApp.Models.TaskManager"
             xmlns:converters="clr-namespace:LifeSyncApp.Converters"
             x:Class="LifeSyncApp.Views.TaskManager.TaskLabel.TaskLabelPage"
             x:DataType="viewmodels:TaskLabelViewModel"
             Title=""
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F4F1">

    <ContentPage.Resources>
        <converters:LabelColorToConverter x:Key="LabelColorToConverter"/>
    </ContentPage.Resources>

    <Grid BackgroundColor="#F5F4F1">
        <Grid RowDefinitions="Auto,*" BackgroundColor="#F5F4F1">

            <!-- Header -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="Auto,*,Auto"
                  Padding="20,12,20,0"
                  BackgroundColor="#F5F4F1">

                <HorizontalStackLayout Grid.Column="0"
                                       Spacing="6"
                                       VerticalOptions="Center">
                    <HorizontalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </HorizontalStackLayout.GestureRecognizers>

                    <Image Source="arrow_back.svg"
                           WidthRequest="20"
                           HeightRequest="20"
                           VerticalOptions="Center"/>

                    <Label Text="Voltar"
                           TextColor="#1A1918"
                           FontSize="15"
                           VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label Grid.Column="2"
                       Text="Etiquetas"
                       TextColor="#1A1918"
                       FontSize="15"
                       FontAttributes="Bold"
                       VerticalOptions="Center"/>
            </Grid>

            <!-- Skeleton Loading -->
            <ScrollView Grid.Row="1"
                        x:Name="SkeletonContainer"
                        IsVisible="{Binding IsLoadingLabels}"
                        BackgroundColor="#F5F4F1"
                        Padding="0">
                <VerticalStackLayout Spacing="16" Padding="20,16,20,20" BackgroundColor="#F5F4F1">

                    <!-- Button Skeleton -->
                    <Border HeightRequest="48"
                            BackgroundColor="#EDECEA"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            StrokeThickness="0"
                            HorizontalOptions="Fill"/>

                    <!-- Labels List Skeleton -->
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="#E5E4E1"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="0">

                        <VerticalStackLayout>
                            <!-- Row 1 -->
                            <Grid Padding="16" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <Border WidthRequest="12" HeightRequest="12" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="1" HeightRequest="14" WidthRequest="80" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center"/>
                                <Border Grid.Column="2" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="3" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                            </Grid>
                            <Border HeightRequest="1" BackgroundColor="#E5E4E1" Stroke="Transparent" StrokeThickness="0" Margin="0"/>

                            <!-- Row 2 -->
                            <Grid Padding="16" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <Border WidthRequest="12" HeightRequest="12" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="1" HeightRequest="14" WidthRequest="65" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center"/>
                                <Border Grid.Column="2" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="3" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                            </Grid>
                            <Border HeightRequest="1" BackgroundColor="#E5E4E1" Stroke="Transparent" StrokeThickness="0" Margin="0"/>

                            <!-- Row 3 -->
                            <Grid Padding="16" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <Border WidthRequest="12" HeightRequest="12" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="1" HeightRequest="14" WidthRequest="70" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center"/>
                                <Border Grid.Column="2" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="3" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                            </Grid>
                            <Border HeightRequest="1" BackgroundColor="#E5E4E1" Stroke="Transparent" StrokeThickness="0" Margin="0"/>

                            <!-- Row 4 -->
                            <Grid Padding="16" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                                <Border WidthRequest="12" HeightRequest="12" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="1" HeightRequest="14" WidthRequest="75" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 6" Stroke="Transparent" StrokeThickness="0" HorizontalOptions="Start" VerticalOptions="Center"/>
                                <Border Grid.Column="2" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                                <Border Grid.Column="3" HeightRequest="18" WidthRequest="18" BackgroundColor="#EDECEA" StrokeShape="RoundRectangle 4" Stroke="Transparent" StrokeThickness="0" VerticalOptions="Center"/>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Content -->
            <ScrollView Grid.Row="1"
                        Padding="20,16,20,20"
                        IsVisible="{Binding IsLoadingLabels, Converter={StaticResource InvertedBoolConverter}}">
                <VerticalStackLayout Spacing="16">

                    <!-- New Label Button -->
                    <Border HeightRequest="48"
                            StrokeShape="RoundRectangle 16"
                            Stroke="Transparent"
                            BackgroundColor="#3D8A5A">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding OpenCreateNewLabelCommand}"/>
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="8"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                            <Image Source="add.svg"
                                   WidthRequest="16"
                                   HeightRequest="16"/>
                            <Label Text="Nova Etiqueta"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Labels List Card -->
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="#E5E4E1"
                            StrokeThickness="1"
                            BackgroundColor="White"
                            Padding="0">
                        <Border.Shadow>
                            <Shadow Brush="#1A1918"
                                    Offset="0,2"
                                    Radius="12"
                                    Opacity="0.03"/>
                        </Border.Shadow>

                        <CollectionView ItemsSource="{Binding TaskLabels}"
                                        SelectionMode="None">
                            <CollectionView.EmptyView>
                                <VerticalStackLayout HorizontalOptions="Center"
                                                     VerticalOptions="Center"
                                                     Spacing="12"
                                                     Padding="20,10">
                                    <Label Text="Nenhuma etiqueta criada"
                                           FontSize="16"
                                           TextColor="#9C9B99"
                                           HorizontalOptions="Center"/>
                                    <Label Text="Toque em 'Nova' para criar sua primeira etiqueta"
                                           FontSize="14"
                                           TextColor="#6D6C6A"
                                           HorizontalTextAlignment="Center"
                                           HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:TaskLabel">
                                    <VerticalStackLayout>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                              Padding="16, 12"
                                              ColumnSpacing="12">

                                            <Ellipse WidthRequest="12"
                                                     HeightRequest="12"
                                                     Fill="{Binding LabelColor, Converter={StaticResource LabelColorToConverter}}"
                                                     VerticalOptions="Center"/>

                                            <Label Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="15"
                                                   TextColor="#1A1918"
                                                   VerticalOptions="Center"/>

                                            <ImageButton Grid.Column="2"
                                                         Source="edit.svg"
                                                         MaximumWidthRequest="36"
                                                         MaximumHeightRequest="36"
                                                         BackgroundColor="Transparent"
                                                         Padding="8"
                                                         VerticalOptions="Center"
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TaskLabelViewModel}}, Path=EditLabelCommand}"
                                                         CommandParameter="{Binding .}"/>

                                            <ImageButton Grid.Column="3"
                                                         Source="trash.svg"
                                                         MaximumWidthRequest="36"
                                                         MaximumHeightRequest="36"
                                                         BackgroundColor="Transparent"
                                                         Padding="8"
                                                         VerticalOptions="Center"
                                                         Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:TaskLabelViewModel}}, Path=DeleteLabelCommand}"
                                                         CommandParameter="{Binding .}"/>
                                        </Grid>
                                        <Border HeightRequest="1" BackgroundColor="#E5E4E1" Stroke="Transparent" StrokeThickness="0" Margin="16,0"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
