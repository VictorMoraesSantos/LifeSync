<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:enums="clr-namespace:LifeSyncApp.Models.TaskManager.Enums"
             xmlns:viewmodels="clr-namespace:LifeSyncApp.ViewModels.TaskManager"
             x:Class="LifeSyncApp.Views.TaskManager.TaskLabel.ManageTaskLabelModal"
             x:DataType="viewmodels:TaskLabelViewModel"
             Shell.PresentationMode="ModalNotAnimated"
             BackgroundColor="Transparent">

    <Grid BackgroundColor="#80000000">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding CloseManageLabelModalCommand}"/>
        </Grid.GestureRecognizers>

        <Border VerticalOptions="End"
                HorizontalOptions="Fill"
                BackgroundColor="White"
                StrokeThickness="0"
                MaximumHeightRequest="500">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24,24,0,0"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Radius="20" Opacity="0.15"/>
            </Border.Shadow>

            <Border.GestureRecognizers>
                <TapGestureRecognizer/>
            </Border.GestureRecognizers>

            <Grid RowDefinitions="Auto,*" RowSpacing="0">

                <!-- Handle + Header -->
                <VerticalStackLayout Grid.Row="0">
                    <Border HorizontalOptions="Center"
                            WidthRequest="40"
                            HeightRequest="4"
                            StrokeShape="RoundRectangle 100"
                            StrokeThickness="0"
                            BackgroundColor="#D1D0CD"
                            Margin="0,12,0,0"/>

                    <Grid ColumnDefinitions="*,Auto" Padding="20,16">
                        <Label Text="{Binding ModalTitle}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#1A1918"
                               VerticalOptions="Center"/>

                        <ImageButton Grid.Column="1"
                                     Source="close.svg"
                                     BackgroundColor="Transparent"
                                     Padding="8"
                                     Command="{Binding CloseManageLabelModalCommand}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- Form Content -->
                <ScrollView Grid.Row="1" Padding="20,0,20,20">
                    <VerticalStackLayout Spacing="24">

                        <!-- Label Name -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Nome da Etiqueta" FontSize="14" FontAttributes="Bold" TextColor="#1A1918"/>
                            <Border Stroke="#E5E4E1" StrokeThickness="1" StrokeShape="RoundRectangle 12" BackgroundColor="#FAFAF8"
                                    HeightRequest="44">
                                <Entry Placeholder="Ex: Trabalho, Pessoal, Urgente..."
                                       PlaceholderColor="#9C9B99"
                                       Text="{Binding LabelName}"
                                       BackgroundColor="Transparent"
                                       Margin="16,0"/>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Color Selection -->
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Escolha uma cor" FontSize="14" FontAttributes="Bold" TextColor="#1A1918"/>

                            <!-- Row 1: Red, Blue, Green, Yellow -->
                            <Grid ColumnDefinitions="*,*,*,*"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="10"
                                  RowSpacing="10">

                                <!-- Red -->
                                <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#FF4444"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Red}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Red}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Vermelho" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Blue -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#4A5FA8"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Blue}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Blue}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Azul" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Green -->
                                <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#3D8A5A"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Green}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Green}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Verde" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Yellow -->
                                <VerticalStackLayout Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#D4A64A"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Yellow}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Yellow}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Amarelo" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Row 2: Purple, Orange, Pink, Gray -->
                                <!-- Purple -->
                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#8B5CF6"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Purple}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Purple}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Roxo" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Orange -->
                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#D89575"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Orange}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Orange}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Laranja" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Pink -->
                                <VerticalStackLayout Grid.Row="1" Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#F472B6"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Pink}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Pink}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Rosa" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>

                                <!-- Gray -->
                                <VerticalStackLayout Grid.Row="1" Grid.Column="3" Spacing="4" HorizontalOptions="Center">
                                    <Border WidthRequest="72"
                                            HeightRequest="72"
                                            StrokeShape="RoundRectangle 16"
                                            BackgroundColor="#9C9B99"
                                            Stroke="Transparent"
                                            StrokeThickness="3">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding SelectColorCommand}"
                                                                  CommandParameter="{x:Static enums:LabelColor.Gray}"/>
                                        </Border.GestureRecognizers>
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border"
                                                         Binding="{Binding SelectedLabelColor}"
                                                         Value="{x:Static enums:LabelColor.Gray}">
                                                <Setter Property="Stroke" Value="#1A1918"/>
                                            </DataTrigger>
                                        </Border.Triggers>
                                    </Border>
                                    <Label Text="Cinza" FontSize="10" TextColor="#6D6C6A" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- Action Buttons -->
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 100"
                                    Stroke="#E5E4E1"
                                    StrokeThickness="1"
                                    BackgroundColor="White"
                                    Padding="14,14"
                                    HeightRequest="48">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CloseManageLabelModalCommand}"/>
                                </Border.GestureRecognizers>
                                <Label Text="Cancelar"
                                       FontSize="14"
                                       TextColor="#6D6C6A"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 100"
                                    StrokeThickness="0"
                                    BackgroundColor="#3D8A5A"
                                    Padding="14,14"
                                    HeightRequest="48">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SaveLabelCommand}"/>
                                </Border.GestureRecognizers>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding CanSaveLabel}"
                                                 Value="False">
                                        <Setter Property="Opacity" Value="0.5"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <HorizontalStackLayout Spacing="6"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center">
                                    <Label Text="{Binding SaveButtonText}"
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="White"/>
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
