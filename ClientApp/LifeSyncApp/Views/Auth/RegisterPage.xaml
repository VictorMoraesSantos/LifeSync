<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LifeSyncApp.Views.Auth.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource FinBackground}">

    <ScrollView VerticalScrollBarVisibility="Never">
        <VerticalStackLayout Spacing="24"
                             Padding="24,60">

            <!-- Back Button -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="&#x2190;"
                       FontSize="20"
                       TextColor="{StaticResource FinDark}"
                       VerticalOptions="Center"/>
                <Label Text="Voltar"
                       FontFamily="OpenSansRegular"
                       FontSize="14"
                       TextColor="{StaticResource FinDark}"
                       VerticalOptions="Center"/>
                <HorizontalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </HorizontalStackLayout.GestureRecognizers>
            </HorizontalStackLayout>

            <!-- Header -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="Criar conta"
                       FontFamily="OutfitSemiBold"
                       FontSize="32"
                       TextColor="{StaticResource FinDark}"
                       HorizontalOptions="Center"/>
                <Label Text="Preencha os dados para comecar"
                       FontFamily="OpenSansRegular"
                       FontSize="14"
                       TextColor="{StaticResource FinSecondaryText}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <!-- Form -->
            <VerticalStackLayout Spacing="14">
                <!-- Name Row -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <VerticalStackLayout Grid.Column="0" Spacing="6">
                        <Label Text="Nome"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               TextColor="{StaticResource FinSecondaryText}"/>
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="{StaticResource FinBorder}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource FinCardBg}"
                                HeightRequest="48"
                                Padding="16,0">
                            <Entry Placeholder="Victor"
                                   PlaceholderColor="{StaticResource FinMuted}"
                                   Text="{Binding FirstName}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   ReturnType="Next"
                                   VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                        <Label Text="Sobrenome"
                               FontFamily="OpenSansRegular"
                               FontSize="13"
                               TextColor="{StaticResource FinSecondaryText}"/>
                        <Border StrokeShape="RoundRectangle 16"
                                Stroke="{StaticResource FinBorder}"
                                StrokeThickness="1"
                                BackgroundColor="{StaticResource FinCardBg}"
                                HeightRequest="48"
                                Padding="16,0">
                            <Entry Placeholder="Silva"
                                   PlaceholderColor="{StaticResource FinMuted}"
                                   Text="{Binding LastName}"
                                   FontFamily="OpenSansRegular"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   ReturnType="Next"
                                   VerticalOptions="Center"/>
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <!-- Email -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="E-mail"
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           TextColor="#71717A"/>
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource FinBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource FinCardBg}"
                            HeightRequest="48"
                            Padding="16,0">
                        <Entry Placeholder="seu@email.com"
                               PlaceholderColor="{StaticResource FinMuted}"
                               Text="{Binding Email}"
                               Keyboard="Email"
                               FontFamily="OpenSansRegular"
                               FontSize="14"
                               TextColor="#000000"
                               ReturnType="Next"
                               VerticalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Password -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Senha"
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           TextColor="#71717A"/>
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource FinBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource FinCardBg}"
                            HeightRequest="48"
                            Padding="16,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="PasswordEntry"
                                   Grid.Column="0"
                                   Placeholder="Min. 6 caracteres"
                                   PlaceholderColor="{StaticResource FinMuted}"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   FontFamily="OpenSansRegular"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   ReturnType="Next"
                                   VerticalOptions="Center"/>
                            <Image x:Name="PasswordEyeIcon"
                                   Grid.Column="1"
                                   Source="eye_on.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   VerticalOptions="Center"
                                   Margin="8,0,0,0">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTogglePasswordTapped"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- Confirm Password -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="Confirmar senha"
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           TextColor="#71717A"/>
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource FinBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource FinCardBg}"
                            HeightRequest="48"
                            Padding="16,0">
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="ConfirmPasswordEntry"
                                   Grid.Column="0"
                                   Placeholder="Repita a senha"
                                   PlaceholderColor="{StaticResource FinMuted}"
                                   Text="{Binding ConfirmPassword}"
                                   IsPassword="True"
                                   FontFamily="OpenSansRegular"
                                   FontSize="14"
                                   TextColor="{StaticResource FinDark}"
                                   ReturnType="Done"
                                   VerticalOptions="Center"/>
                            <Image x:Name="ConfirmPasswordEyeIcon"
                                   Grid.Column="1"
                                   Source="eye_on.png"
                                   WidthRequest="20"
                                   HeightRequest="20"
                                   VerticalOptions="Center"
                                   Margin="8,0,0,0">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnToggleConfirmPasswordTapped"/>
                                </Image.GestureRecognizers>
                            </Image>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <!-- Error Message -->
            <Label Text="{Binding ErrorMessage}"
                   IsVisible="{Binding HasError}"
                   TextColor="#C62828"
                   FontFamily="OpenSansRegular"
                   FontSize="13"
                   HorizontalTextAlignment="Center"
                   Margin="0,-8,0,0"/>

            <!-- Actions -->
            <VerticalStackLayout Spacing="16">
                <Button Text="Criar conta"
                        Clicked="OnRegisterClicked"
                        BackgroundColor="{StaticResource FinGreen}"
                        TextColor="White"
                        FontFamily="OutfitSemiBold"
                        FontSize="16"
                        HeightRequest="52"
                        CornerRadius="16"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"/>

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource FinDark}"
                                   HeightRequest="20"
                                   HorizontalOptions="Center"/>

                <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                    <Label Text="Ja tem uma conta?"
                           FontFamily="OpenSansRegular"
                           FontSize="13"
                           TextColor="{StaticResource FinMuted}"
                           VerticalOptions="Center"/>
                    <Label Text="Entrar"
                           FontFamily="OpenSansSemibold"
                           FontSize="13"
                           TextColor="{StaticResource FinDark}"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnLoginTapped"/>
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
